@using RISOS.Services
@using RISOS.Common.Models

<MudDialog>
    <TitleContent>
        <MudStack Row Spacing="3" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Cookie" Color="Color.Primary"/>
            <MudText Typo="Typo.h6" Class="font-weight-bold">
                Privacy & Analytics
            </MudText>
        </MudStack>
        <MudDivider Class="mt-2"/>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="mud-text-secondary mt-4">
            We use analytics to improve your RISOS experience. Your choice helps us build a better tool for everyone. 
        </MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2 d-block">
            Strictly necessary cookies are always active.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudStack Row Spacing="2" Class="pa-2 w-100">
            <MudButton 
                Variant="Variant.Outlined" 
                Color="Color.Primary" 
                OnClick="(() => HandleConsent(false))"
                FullWidth="true"
                Style="text-transform: none; font-weight: bold; border-width: 2px;">
                Necessary Only
            </MudButton>
            <MudButton 
                Variant="Variant.Filled" 
                Color="Color.Primary" 
                OnClick="(() => HandleConsent(true))"
                FullWidth="true"
                Style="text-transform: none; font-weight: bold; box-shadow: none;">
                Accept All
            </MudButton>
        </MudStack>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Inject]
    public required AnalyticsService AnalyticsService { get; set; }

    [Inject]
    public required LocalStorageService LocalStorage { get; set; }

    private async Task HandleConsent(bool granted)
    {
        await LocalStorage.SaveAnalyticsConsent(granted);
        
        if (granted)
        {
            await AnalyticsService.UpdateConsentAsync(true);
        }

        MudDialog.Close();
    }

    public static async Task ShowAsync(IDialogService dialogService)
    {
        var options = new DialogOptions 
        { 
            CloseOnEscapeKey = false, 
            CloseButton = false, 
            BackdropClick = false,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        await dialogService.ShowAsync<CookieConsentDialog>(string.Empty, options);
    }
}
