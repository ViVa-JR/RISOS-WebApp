@if (IsLoading)
{
    <MudStack Style="width: 100%; height: 100%" AlignItems="AlignItems.Center" Justify="Justify.Center">
        <MudProgressCircular Color="Color.Primary" Indeterminate Size="Size.Large"/>
    </MudStack>
}
else
{
    @ChildContent
}

@code {
    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    [EditorRequired]
    public required RenderFragment ChildContent { get; set; }
}
