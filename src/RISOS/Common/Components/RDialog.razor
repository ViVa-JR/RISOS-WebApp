@typeparam TReturn

@using RISOS.Common.Models
@using RISOS.Localization
@using DialogResult = MudBlazor.DialogResult

<MudDialog Class="pa-2">
    <TitleContent>
        <MudStack Row Spacing="3" AlignItems="AlignItems.Center">
            <MudIcon Icon="@HeaderIcon" Color="Color.Primary"/>
            <MudText Typo="Typo.h6" Class="font-weight-bold">
                @Title
            </MudText>
            <MudSpacer/>
            @HeaderRight
        </MudStack>
        <MudDivider/>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Class="mt-2 pb-2">
            @ChildContent
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudStack Row Spacing="2" AlignItems="AlignItems.Center" Class="w-100 ps-2">
            @FooterLeft
            <MudSpacer/>
            <MudButton OnClick="@Cancel" Color="Color.Default" StartIcon="@Icons.Material.Filled.Close">
                @(OnlyClosable ? LanguageHelper.Close : LanguageHelper.Cancel)
            </MudButton>
            @if (!OnlyClosable)
            {
                <MudButton Color="Color.Primary" Variant="Variant.Outlined" StartIcon="@SubmitIcon"
                           OnClick="@OnSubmitInternal">
                    @SubmitText
                </MudButton>
            }
        </MudStack>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public string Title { get; set; } = "Dialog";

    [Parameter]
    public Func<Task<TReturn>>? OnSubmit { get; set; }

    [Parameter]
    public string SubmitText { get; set; } = LanguageHelper.Submit;

    [Parameter]
    public string? SubmitIcon { get; set; }

    [Parameter]
    [EditorRequired]
    public required RenderFragment ChildContent { get; set; }

    [Parameter]
    public string HeaderIcon { get; set; } = Icons.Material.Filled.School;

    [Parameter]
    public Func<Task<Result>>? OnValidateFunc { get; set; }

    [Parameter]
    public RenderFragment? FooterLeft { get; set; }

    [Parameter]
    public required RenderFragment HeaderRight { get; set; }

    [Parameter]
    public bool OnlyClosable { get; set; }

    private MudForm _form = null!;

    private async Task OnSubmitInternal()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        if (OnValidateFunc is not null)
        {
            var result = await OnValidateFunc.Invoke();
            if (result.IsFailure)
            {
                return;
            }
        }

        if (OnSubmit is null)
        {
            MudDialog.Close();
            return;
        }

        var value = await OnSubmit.Invoke();
        MudDialog.Close(DialogResult.Ok(value));
    }

    private void Cancel() => MudDialog.Cancel();
}
