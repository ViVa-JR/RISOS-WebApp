@page "/"
@using RISOS.Enums
@using RISOS.Models
@using RISOS.Pages.Home.Components
@using RISOS.Pages.Home.Models

<style>
    .side-bar .mud-expand-panel {
        background: var(--mud-palette-primary);
        color: white;
    }

    .card-text {
        white-space: nowrap;
        text-overflow: ellipsis;
        overflow: hidden;
    }

    .mud-drawer.mud-drawer-mini.mud-drawer-pos-left.mud-drawer--open ~ div:not(.mud-main-content), .mud-drawer.mud-drawer-persistent.mud-drawer-pos-left.mud-drawer--open ~ div:not(.mud-main-content) {
        margin-left: 0 !important;
    }

    .mud-drawer.mud-drawer-mini.mud-drawer-pos-left.mud-drawer--closed ~ div:not(.mud-main-content) {
        margin-left: 0 !important;
    }
</style>

<SideBar Class="side-bar">
    <MudExpansionPanels MultiExpansion="true" Elevation="3">
        <MudExpansionPanel Text="Study program">
            Test
        </MudExpansionPanel>
        <MudExpansionPanel Text="Mandatory subjects">
            Test
        </MudExpansionPanel>
        <MudExpansionPanel Text="Non-Mandatory subjects">
            Test
        </MudExpansionPanel>
        <MudExpansionPanel Text="Custom subjects">
            Test
        </MudExpansionPanel>
    </MudExpansionPanels>
</SideBar>

<StudiumDropContainer @bind-Subjects="@_subjects"/>

@code {
    private List<SubjectEntry> _subjects = [];
    
    protected override void OnInitialized()
    {
        var dummySubjects = new List<Subject>
        {
            new("Algorithms and Data Structures", "ALG", 6, 2, SubjectType.Compulsory, SemesterSeason.Summer),
            new("Operating Systems", "MPC-MNM", 5, 3, SubjectType.Compulsory),
            new("Relational Databases", "RDB", 4, 1, SubjectType.CompulsoryElective, SemesterSeason.Winter, "DB_Track"),
            new("Web Development", "WEB", 5, 4, SubjectType.CompulsoryElective, SemesterSeason.Both, "DEV_Track"),
        };

        _subjects = dummySubjects.Select(s => new SubjectEntry(s)).ToList();
    }

}
