@page "/"
@using RISOS.Enums
@using RISOS.Pages.Home.Components
@using RISOS.Pages.Home.Models
@using RISOS.Services

@inject UniversityService UniversityService

<style>
    .side-bar .mud-expand-panel {
        background: var(--mud-palette-primary);
        color: white;
    }

    .mud-drawer.mud-drawer-mini.mud-drawer-pos-left.mud-drawer--open ~ div:not(.mud-main-content), .mud-drawer.mud-drawer-persistent.mud-drawer-pos-left.mud-drawer--open ~ div:not(.mud-main-content) {
        margin-left: 0 !important;
    }

    .mud-drawer.mud-drawer-mini.mud-drawer-pos-left.mud-drawer--closed ~ div:not(.mud-main-content) {
        margin-left: 0 !important;
    }

    .mud-expand-panel-header {
        padding-left: 16px !important;
        padding-right: 16px !important;
    }

    .mud-collapse-entering .mud-expand-panel-content[hidden],
    .mud-collapse-exiting .mud-expand-panel-content[hidden],
    .mud-collapse-entering .mud-expand-panel-content,
    .mud-collapse-exiting .mud-expand-panel-content {
        display: block !important;
        visibility: visible !important;
    }

    .mud-collapse-wrapper {
        overflow: hidden !important;
    }

    .mud-expand-panel-content {
        padding: 0 8px 8px 8px !important;
    }

    .mud-list-item-multiselect-extended {
        padding: 0 0 0 12px !important;
    }

</style>

<SideBar Class="side-bar">
    <OpenedDrawerContent>
        <MudExpansionPanels Elevation="3" Style="height: calc(100vh - 128px); overflow: hidden">
            <MudExpansionPanel Text="Study program" Gutters="false" Expanded="@_expanded" KeepContentAlive="true">
                <StudyProgramSelector SelectedPrograms="_mySelections" SelectedProgramsChanged="OnSelectedProgramsChanged"/>
            </MudExpansionPanel>
            <MudExpansionPanel Text="Compulsory subjects">
                @foreach (var s in _subjects.Where(s => s.Subject.Type != SubjectType.Elective))
                {
                    @s.Subject.ShortName
                    <br/>
                }
            </MudExpansionPanel>
            <MudExpansionPanel Text="Elective subjects">
                @foreach (var s in _subjects.Where(s => s.Subject.Type == SubjectType.Elective))
                {
                    
                    @s.Subject.ShortName
                    <br/>
                }
            </MudExpansionPanel>
        </MudExpansionPanels>
    </OpenedDrawerContent>
    <AlwaysVisible>
        <MudStack Row Justify="Justify.Center" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Class="px-2 pb-2" Style="width: 100%">
            <MudTooltip Text="Settings">
                <MudIconButton Icon="@Icons.Material.Filled.Settings" Style="color: var(--mud-palette-drawer-text)"/>
            </MudTooltip>
            <MudTooltip Text="Export">
                <MudIconButton Icon="@Icons.Material.Filled.Download" Style="color: var(--mud-palette-drawer-text)"/>
            </MudTooltip>
            <MudTooltip Text="Import">
                <MudIconButton Icon="@Icons.Material.Filled.Upload" Style="color: var(--mud-palette-drawer-text)"/>
            </MudTooltip>
        </MudStack>
    </AlwaysVisible>
</SideBar>

<StudiumDropContainer @bind-Subjects="@_subjects" RequiredCredits="@RequiredCredits"/>

@code {
    private List<SubjectEntry> _subjects = [];
    private IEnumerable<StudyProgram> _mySelections = [];

    private bool _expanded = true;

    private int RequiredCredits => _mySelections.FirstOrDefault()?.Credits ?? 0;
    
    private void OnSelectedProgramsChanged(IEnumerable<StudyProgram> programs)
    {
        var studyPrograms = programs.ToList();
        _mySelections = studyPrograms;
        
        Console.WriteLine($"Selected {studyPrograms.Count} study program(s)");
        
        if (studyPrograms.Any())
        {
            Task.Run(async () =>
            {
                try
                {
                    var subjects = await UniversityService.GetSubjectsAsync(studyPrograms.First());
                    Console.WriteLine($"Loaded {subjects.Count} subjects");

                    _subjects = subjects.Select(s => new SubjectEntry(s)).ToList();
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error loading subjects: {ex.Message}");
                }
            });
        }
        else
        {
            Console.WriteLine("No programs selected");
            _subjects.Clear();
        }
        
        StateHasChanged();
    }

}
