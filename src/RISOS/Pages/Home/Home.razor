@page "/"
@using RISOS.Enums
@using RISOS.Pages.Home.Components
@using RISOS.Pages.Home.Models
@using RISOS.Services

@inject UniversityService UniversityService

<style>
    .side-bar .mud-expand-panel {
        background: var(--mud-palette-primary);
        color: white;
    }

    .mud-drawer.mud-drawer-mini.mud-drawer-pos-left.mud-drawer--open ~ div:not(.mud-main-content), .mud-drawer.mud-drawer-persistent.mud-drawer-pos-left.mud-drawer--open ~ div:not(.mud-main-content) {
        margin-left: 0 !important;
    }

    .mud-drawer.mud-drawer-mini.mud-drawer-pos-left.mud-drawer--closed ~ div:not(.mud-main-content) {
        margin-left: 0 !important;
    }

    .mud-expand-panel-header {
        padding-left: 16px !important;
        padding-right: 16px !important;
    }

    .mud-collapse-entering .mud-expand-panel-content[hidden],
    .mud-collapse-exiting .mud-expand-panel-content[hidden],
    .mud-collapse-entering .mud-expand-panel-content,
    .mud-collapse-exiting .mud-expand-panel-content {
        display: block !important;
        visibility: visible !important;
    }

    .mud-collapse-wrapper {
        overflow: hidden !important;
    }

    .mud-expand-panel-content {
        padding: 0 8px 8px 8px !important;
    }

    .mud-list-item-multiselect-extended {
        padding: 0 0 0 12px !important;
    }

</style>

<SideBar Class="side-bar">
    <OpenedDrawerContent>
        <MudExpansionPanels Elevation="3" Style="height: calc(100vh - 128px); overflow: hidden">
            <MudExpansionPanel Text="Study program" Gutters="false">
                <StudyProgramSelector SelectedPrograms="_selectedPrograms" SelectedProgramsChanged="OnSelectedProgramsChanged"/>
            </MudExpansionPanel>
            <SubjectsPanel TGroupKey="int"
                           HeaderTemplate="@(x => $"{x}. Semester")"
                           GroupBy="@(x => x.Subject.MinSemester)"
                           Title="Compulsory"
                           Disabled="@(!_selectedPrograms.Any())"
                           Subjects="CompulsorySubjects"
                           IsLoading="_isLoading"
                           LoadData="LoadData"
                           FixedPixels="326"/>
            <SubjectsPanel TGroupKey="int"
                           HeaderTemplate="@(x => $"{x}. Semester")"
                           GroupBy="@(x => x.Subject.MinSemester)"
                           Title="Compulsory-Elective"
                           Disabled="@(!_selectedPrograms.Any())"
                           Subjects="CompulsoryElectiveSubjects"
                           SelectionMode="SelectionMode.MultiSelection"
                           IsLoading="_isLoading"
                           LoadData="LoadData"
                           SelectedCompulsoryElectiveSubjects="_selectedCompulsoryElective"
                           SelectedCompulsoryElectiveSubjectsChanged="SelectedCompulsoryElectiveSubjectsChanged"
                           FixedPixels="326"/>
            <SubjectsPanel TGroupKey="SemesterSeason"
                           GroupBy="@(x => x.Subject.SemesterSeason)"
                           Title="Elective"
                           Disabled="@(!_selectedPrograms.Any())"
                           Subjects="ElectiveSubjects"
                           SelectionMode="SelectionMode.MultiSelection"
                           IsLoading="_isLoading"
                           LoadData="LoadData"
                           SelectedCompulsoryElectiveSubjects="_selectedElective"
                           SelectedCompulsoryElectiveSubjectsChanged="SelectedElectiveSubjectsChanged"
                           FixedPixels="310"/>
        </MudExpansionPanels>
    </OpenedDrawerContent>
    <AlwaysVisible>
        <MudStack Row Justify="Justify.Center" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Class="px-2 pb-2" Style="width: 100%">
            <MudTooltip Text="Settings">
                <MudIconButton Icon="@Icons.Material.Filled.Settings" Style="color: var(--mud-palette-drawer-text)"/>
            </MudTooltip>
            <MudTooltip Text="Export">
                <MudIconButton Icon="@Icons.Material.Filled.Download" Style="color: var(--mud-palette-drawer-text)"/>
            </MudTooltip>
            <MudTooltip Text="Import">
                <MudIconButton Icon="@Icons.Material.Filled.Upload" Style="color: var(--mud-palette-drawer-text)"/>
            </MudTooltip>
        </MudStack>
    </AlwaysVisible>
</SideBar>

<StudiumDropContainer @ref="_dropContainer" Subjects="@SelectedSubjects" RequiredCredits="@RequiredCredits" OnRemove="OnRemove"/>

@code {
    private List<SubjectEntry> _subjects = [];
    private IEnumerable<StudyProgram> _selectedPrograms = [];
    private ICollection<SubjectEntry> _selectedCompulsoryElective = [];
    private ICollection<SubjectEntry> _selectedElective = [];

    private bool _subjectsLoaded;
    private bool _isLoading;
    private StudiumDropContainer _dropContainer = null!;

    private int RequiredCredits => _selectedPrograms.FirstOrDefault()?.Credits ?? 0;
    private ICollection<SubjectEntry> CompulsorySubjects => _subjects.Where(s => s.Subject.Type == SubjectType.Compulsory).ToList();
    private ICollection<SubjectEntry> CompulsoryElectiveSubjects => _subjects.Where(s => s.Subject.Type == SubjectType.CompulsoryElective).ToList();
    private ICollection<SubjectEntry> ElectiveSubjects => _subjects.Where(s => s.Subject.Type == SubjectType.Elective).ToList();
    private List<SubjectEntry> SelectedSubjects => CompulsorySubjects.Concat(_selectedCompulsoryElective).Concat(_selectedElective).ToList();

    private async Task<bool> LoadData(bool expand)
    {
        if (!_selectedPrograms.Any())
        {
            return false;
        }

        if (!expand || _subjectsLoaded)
        {
            return true;
        }

        _isLoading = true;
        await InvokeAsync(StateHasChanged);

        _subjects = (await UniversityService.GetSubjectsAsync(_selectedPrograms.First())).Select(s => new SubjectEntry(s)).ToList();
        Console.WriteLine($"Loaded {_subjects.Count} subjects");
        _subjectsLoaded = true;
        _isLoading = false;
        await InvokeAsync(StateHasChanged);
        _dropContainer.Refresh();
        return true;
    }

    private void OnSelectedProgramsChanged(IEnumerable<StudyProgram> programs)
    {
        var studyPrograms = programs.ToList();
        _selectedPrograms = studyPrograms;

        Console.WriteLine($"Selected {studyPrograms.Count} study program(s)");

        if (!studyPrograms.Any())
        {
            _subjects.Clear();
        }

        _subjectsLoaded = false;
        StateHasChanged();
    }

    private void OnRemove(SubjectEntry entry)
    {
        _selectedElective.Remove(entry);
        _selectedCompulsoryElective.Remove(entry);
    }

    private void SelectedCompulsoryElectiveSubjectsChanged(ICollection<SubjectEntry> arg)
    {
        _selectedElective = arg;
        _dropContainer.Refresh();
    }

    private void SelectedElectiveSubjectsChanged(ICollection<SubjectEntry> arg)
    {
        _selectedCompulsoryElective = arg;
        _dropContainer.Refresh();
    }

}
