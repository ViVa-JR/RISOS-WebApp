@page "/"
@using RISOS.Common.Models
@using RISOS.Enums
@using RISOS.Extensions
@using RISOS.Helpers
@using RISOS.Localization
@using RISOS.Mappers
@using RISOS.Pages.Home.Components
@using RISOS.Pages.Home.Components.MobileLayout
@using RISOS.Pages.Home.Dialogs.ImportDialog
@using RISOS.Pages.Home.Dialogs.SettingsDialog
@using RISOS.Pages.Home.Dialogs.ShareDialog
@using RISOS.Pages.Home.Dialogs.WhatsNewDialog
@using RISOS.Pages.Home.Models
@using RISOS.Services

@inject UniversityService UniversityService
@inject IDialogService DialogService
@inject LanguageService LanguageService
@inject NavigationManager NavigationManager
@inject LocalStorageService LocalStorageService
@inject ExportService ExportService
@inject ImportService ImportService
@inject ThemeStateService ThemeStateService
@inject AnalyticsService AnalyticsService
@inject StudyPlanService PlanService

<style>
    :root {
        --dropzone-height: 250px;
    }

    .side-bar .mud-expand-panel {
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
    }

    .mud-drawer.mud-drawer-mini.mud-drawer-pos-left.mud-drawer--open ~ div:not(.mud-main-content), .mud-drawer.mud-drawer-persistent.mud-drawer-pos-left.mud-drawer--open ~ div:not(.mud-main-content) {
        margin-left: 0 !important;
    }

    .mud-drawer.mud-drawer-mini.mud-drawer-pos-left.mud-drawer--closed ~ div:not(.mud-main-content) {
        margin-left: 0 !important;
    }

    .mud-expand-panel-header {
        padding-left: 16px !important;
        padding-right: 16px !important;
    }

    .mud-collapse-entering .mud-expand-panel-content[hidden],
    .mud-collapse-exiting .mud-expand-panel-content[hidden],
    .mud-collapse-entering .mud-expand-panel-content,
    .mud-collapse-exiting .mud-expand-panel-content {
        display: block !important;
        visibility: visible !important;
    }

    .mud-collapse-wrapper {
        overflow: hidden !important;
    }

    .mud-expand-panel-content {
        padding: 0 8px 8px 8px !important;
    }

    .mud-list-item-multiselect-extended {
        padding: 0 0 0 12px !important;
    }

    .side-bar .mud-expand-panel-header .mud-chip:not(.mud-chip-color-error):not(.mud-chip-color-secondary):not(.mud-chip-color-tertiary) {
        color: var(--mud-palette-text-primary) !important;
        border-color: var(--mud-palette-text-secondary) !important;
    }

    .side-bar .mud-expand-panel-header .mud-badge:not(.mud-badge-error):not(.mud-badge-secondary):not(.mud-badge-tertiary) {
        color: var(--mud-palette-text-primary) !important;
        border-color: var(--mud-palette-text-secondary) !important;
    }
</style>

<SideBar Class="side-bar" DrawerOpenChanged="@ToggleExpansionPanels">
    <OpenedDrawerContent>
        <MudExpansionPanels MultiExpansion="false" Elevation="3" Style="height: calc(100vh - 128px); overflow: hidden">
            <MudExpansionPanel Text="@LanguageHelper.StudyProgram" Gutters="false" @bind-Expanded="_studyProgramExpanded">
                <StudyProgramSelector SelectedProgram="@_selectedProgram"
                                      SelectedProgramChanged="@OnSelectedProgramsChanged" Loading="@_isLoading"/>
            </MudExpansionPanel>
            <SubjectsPanel TGroupKey="int"
                           HeaderTemplate="@(n => n <= 0 ? LanguageHelper.Any : LanguageHelperExtensions.Semester(n))"
                           GroupBy="@(x => x.Subject.MinSemester)"
                           SubjectChanged="@SubjectChanged"
                           Title="@LanguageHelper.Compulsory"
                           Disabled="@Disabled"
                           Subjects="@CompulsorySubjects"
                           IsLoading="@_isLoading"
                           FixedPixels="382"
                           @bind-Expanded="_compulsoryExpanded"
                           ReadOnly/>
            <SubjectsPanel TGroupKey="string"
                           GroupBy="@(x => x.Subject.GroupId!)"
                           SubjectChanged="@SubjectChanged"
                           Title="@LanguageHelper.CompulsoryElective"
                           Disabled="@Disabled"
                           Subjects="@CompulsoryElectiveSubjects"
                           IsLoading="@_isLoading"
                           FixedPixels="382"
                           @bind-Expanded="_compulsoryElectiveExpanded"
                           CompulsoryGroups/>
            <SubjectsPanel TGroupKey="SemesterSeason"
                           GroupBy="@(x => x.Subject.SemesterSeason)"
                           HeaderTemplate="@(x => x.ToLabel())"
                           SubjectChanged="@SubjectChanged"
                           Title="@LanguageHelper.Elective"
                           Disabled="@Disabled"
                           Subjects="@ElectiveSubjects"
                           IsLoading="@_isLoading"
                           FixedPixels="382"
                           @bind-Expanded="_electiveExpanded"/>
            <SubjectsPanel TGroupKey="SemesterSeason"
                           GroupBy="@(x => x.Subject.SemesterSeason)"
                           HeaderTemplate="@(x => x.ToLabel())"
                           SubjectChanged="@SubjectChanged"
                           Title="@LanguageHelper.Sport"
                           Disabled="@Disabled"
                           Subjects="@SportSubjects"
                           IsLoading="@_isLoading"
                           FixedPixels="366"
                           @bind-Expanded="_sportExpanded"/>
        </MudExpansionPanels>
    </OpenedDrawerContent>
    <AlwaysVisible>
        <MudStack Row Justify="Justify.SpaceAround" Spacing="0" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap"
                  Class="px-1 pb-2" Style="width: 100%">
            <MudTooltip Text="@LanguageHelper.WhatsNew">
                <MudIconButton
                    Icon="@Icons.Material.Filled.Info"
                    Style="color: var(--mud-palette-drawer-text)"
                    OnClick="@OnWhatsNewClick"/>
            </MudTooltip>
            <MudTooltip Text="@LanguageHelper.Settings">
                <MudIconButton Icon="@Icons.Material.Filled.Settings" Style="color: var(--mud-palette-drawer-text)"
                               OnClick="@OnSettingsClick"/>
            </MudTooltip>
            <MudMenu Dense AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                <ActivatorContent>
                    <MudTooltip Text="@LanguageHelper.Export">
                        <MudIconButton Icon="@Icons.Material.Filled.Download" Style="color: var(--mud-palette-drawer-text)" OnClick="@context.ToggleAsync"/>
                    </MudTooltip>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem Icon="@Icons.Material.Filled.Image" OnClick="@(() => ExportService.ExportAsImageAsync())">@LanguageHelper.ExportAsImage</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.DataObject" OnClick="@(() => ExportService.HandleExportAsync())">@LanguageHelper.ExportAsJson</MudMenuItem>
                </ChildContent>
            </MudMenu>
            <MudTooltip Text="@LanguageHelper.Import">
                <MudIconButton
                    Icon="@Icons.Material.Filled.Upload"
                    Style="color: var(--mud-palette-drawer-text)"
                    OnClick="@OnImportClick"/>
            </MudTooltip>
            <MudTooltip Text="@LanguageHelper.Share">
                <MudIconButton
                    Icon="@Icons.Material.Filled.Share"
                    Style="color: var(--mud-palette-drawer-text)"
                    OnClick="@OnShareClick"/>
            </MudTooltip>
        </MudStack>
    </AlwaysVisible>
</SideBar>

<CascadingValue Value="_studyContext">
    @if (IsReadOnly)
    {
        <MobileStudyPlanView Subjects="@PlanService.Subjects.ToList()" RecognizedYear="@_recognizedYear" LocalStorageLoading="@_dropZoneContainerLoading"/>
    }
    else
    {
        <StudiumDropContainer @ref="@_dropContainer" @bind-RecognizedYear="@_recognizedYear" LocalStorageLoading="@_dropZoneContainerLoading" AllSubjects="@_availableSubjects.Values"/>
    }
</CascadingValue>

@code {
    [CascadingParameter]
    public bool IsReadOnly { get; set; }

    private Dictionary<SubjectEntryKey, SubjectEntry> _availableSubjects = [];
    private StudyProgram? _selectedProgram;

    private bool _isLoading;
    private bool _dropZoneContainerLoading;
    private bool _recognizedYear;
    private bool _studyProgramExpanded;
    private bool _compulsoryExpanded;
    private bool _compulsoryElectiveExpanded;
    private bool _electiveExpanded;
    private bool _sportExpanded;
    private StudiumDropContainer? _dropContainer;

    private readonly StudyContext _studyContext = new();

    private Dictionary<SubjectEntryKey, SubjectEntry> CompulsorySubjects => _availableSubjects.Where(s => s.Value.Subject.Type == SubjectType.Compulsory && !s.Value.IsCustomSubject).OrderBy(x => x.Value.Subject.ShortName).ToDictionary();
    private Dictionary<SubjectEntryKey, SubjectEntry> CompulsoryElectiveSubjects => _availableSubjects.Where(s => s.Value.Subject.Type == SubjectType.CompulsoryElective && !s.Value.IsCustomSubject).OrderBy(x => x.Value.Subject.ShortName).ToDictionary();
    private Dictionary<SubjectEntryKey, SubjectEntry> ElectiveSubjects => _availableSubjects.Where(s => s.Value.Subject.Type == SubjectType.Elective && !s.Value.IsCustomSubject).OrderBy(x => x.Value.Subject.ShortName).ToDictionary();
    private Dictionary<SubjectEntryKey, SubjectEntry> SportSubjects => _availableSubjects.Where(s => s.Value.Subject.Type == SubjectType.Sport && !s.Value.IsCustomSubject).OrderBy(x => x.Value.Subject.ShortName).ToDictionary();

    private bool Disabled => _selectedProgram is null;

    protected override async Task OnInitializedAsync()
    {
        PlanService.OnPlanChanged += StateHasChanged;
        await HandleUrlStateAsync();
        await InitializeSelectedProgramAsync();
    }

    private async Task HandleUrlStateAsync()
    {
        var uri = new Uri(NavigationManager.Uri);
        if (string.IsNullOrEmpty(uri.Fragment) || uri.Fragment.Length <= 1)
        {
            return;
        }

        var encodedData = uri.Fragment[1..];
        try
        {
            var appState = AppStateEncoder.Decode<AppState>(encodedData);
            if (appState is not null)
            {
                await ImportService.ApplyAppStateAsync(appState);
            }

            NavigationManager.NavigateTo(uri.GetLeftPart(UriPartial.Path), replace: true);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    private async Task InitializeSelectedProgramAsync()
    {
        var faculties = await UniversityService.GetFacultiesWithProgramsAsync();
        var programAbbreviation = await LocalStorageService.LoadProgramAbbreviation();
        var specialization = await LocalStorageService.LoadProgramSpecialization();

        if (faculties.IsSuccess && !string.IsNullOrEmpty(programAbbreviation))
        {
            var program = faculties.Value
                .SelectMany(f => f.Programs)
                .FirstOrDefault(p => p.Abbreviation == programAbbreviation && p.Specialization == specialization);

            if (program != null)
            {
                _studyProgramExpanded = false;
                await OnSelectedProgramsChanged(program);
                return;
            }
        }

        _studyProgramExpanded = true;
    }

    private async Task LoadData(StudyProgram studyProgram, bool fromStorage)
    {
        _isLoading = true;
        await InvokeAsync(StateHasChanged);

        var result = await UniversityService.GetSubjectsAsync(studyProgram);
        if (result.IsSuccess)
        {
            await InitializeSubjectsAsync(result.Value, fromStorage);
        }

        await LoadUserPreferencesAsync();

        _isLoading = false;
        await InvokeAsync(StateHasChanged);
        _dropContainer?.Refresh();
    }

    private async Task InitializeSubjectsAsync(IEnumerable<Subject> subjects, bool fromStorage)
    {
        _availableSubjects = subjects.Select(s => new SubjectEntry(s)).ToDictionary(x => x.Key);
        if (!fromStorage)
        {
            var selected = _availableSubjects.Values.Where(x => x.Selected).ToList();
            var groupedBySemester = selected.GroupBy(x => x.Semester);
            foreach (var semesterGroup in groupedBySemester)
            {
                var currentIndex = 0;
                foreach (var subject in semesterGroup)
                {
                    subject.IndexInZone = currentIndex;
                    currentIndex++;
                }
            }

            PlanService.SetSubjects(selected);
            await LocalStorageService.SaveSubjects(SubjectStorageMapper.ToStorageList(selected));
        }
        else
        {
            await SyncSubjectsFromStorage();
        }
    }

    private async Task LoadUserPreferencesAsync()
    {
        var creditOverride = await LocalStorageService.LoadCreditOverride();
        if (creditOverride.HasValue)
        {
            _studyContext.CreditOverride = creditOverride.Value;
        }

        _studyContext.GpaPredictor = await LocalStorageService.LoadGpaPredictor();
        _recognizedYear = await LocalStorageService.LoadRecognizedYear();
    }

    private async Task OnSelectedProgramsChanged(StudyProgram? program)
    {
        _dropZoneContainerLoading = true;
        await InvokeAsync(StateHasChanged);

        _selectedProgram = program;

        var savedAbbreviation = await LocalStorageService.LoadProgramAbbreviation();
        var savedSpecialization = await LocalStorageService.LoadProgramSpecialization();
        var isSameProgram = program?.Abbreviation == savedAbbreviation && program?.Specialization == savedSpecialization;

        await UpdateStudyContextAsync(program, isSameProgram);
        await LocalStorageService.SaveProgramAbbreviation(program?.Abbreviation);
        await LocalStorageService.SaveProgramSpecialization(program?.Specialization);

        if (_selectedProgram is null)
        {
            _availableSubjects.Clear();
            PlanService.SetSubjects(Enumerable.Empty<SubjectEntry>());
            await LocalStorageService.ResetSubjectsAsync();
        }
        else
        {
            await LoadData(_selectedProgram, isSameProgram);
        }

        _dropZoneContainerLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task UpdateStudyContextAsync(StudyProgram? program, bool isSameProgram)
    {
        _studyContext.ProgramAbbreviation = program?.Abbreviation;
        _studyContext.ProgramSpecialization = program?.Specialization;

        if (program != null)
        {
            var faculties = await UniversityService.GetFacultiesWithProgramsAsync();
            _studyContext.FacultyAbbreviation = faculties.Value.FirstOrDefault(f => f.Programs.Any(p => p.Abbreviation == program.Abbreviation && p.Specialization == program.Specialization))?.Abbreviation;
        }
        else
        {
            _studyContext.FacultyAbbreviation = null;
        }

        if (isSameProgram)
        {
            var savedYears = await LocalStorageService.LoadStudyYears();
            _studyContext.Years = savedYears ?? (int)Math.Ceiling(_selectedProgram?.StudyDuration ?? 3.0);
        }
        else
        {
            _studyContext.Years = (int)Math.Ceiling(_selectedProgram?.StudyDuration ?? 3.0);
            await LocalStorageService.SaveStudyYears(_studyContext.Years);
        }

        _studyContext.RequiredCredits = _selectedProgram?.Credits ?? 0;
        _studyContext.CreditsWarn = _selectedProgram?.CreditsWarn ?? true;
    }

    private async Task SubjectChanged(SubjectEntry subject)
    {
        await AnalyticsService.TrackSubjectClickAsync(subject);

        if (subject.IsSport)
        {
            await PlanService.DuplicateSportAsync(subject);
            return;
        }

        _availableSubjects[subject.Key] = subject;

        if (subject.Selected)
        {
            subject.IndexInZone = PlanService.Subjects.Count(x => x.Semester == subject.Semester);
            await PlanService.AddSubjectAsync(subject);
        }
        else
        {
            await PlanService.RemoveSubjectAsync(subject);
        }

        _dropContainer?.Refresh();
    }

    private async Task OnSettingsClick()
    {
        var previousTheme = ThemeStateService.CurrentThemeType ?? ThemeType.Default;
        var previousLanguage = await LanguageService.GetAppLanguageAsync();

        var result = await SettingsDialog.ShowAsync(DialogService, _studyContext);
        if (result.IsCancelled || result.IsFailure)
        {
            return;
        }

        _studyContext.CreditOverride = result.Value.Credits;
        await LocalStorageService.SaveCreditOverride(result.Value.Credits);
        _studyContext.GpaPredictor = result.Value.GpaPredictor;
        await LocalStorageService.SaveGpaPredictor(result.Value.GpaPredictor);
        await ThemeStateService.SetThemeType(result.Value.SelectedTheme);
        if (result.Value.SelectedTheme != previousTheme)
        {
            await AnalyticsService.TrackThemeChangedAsync(previousTheme, result.Value.SelectedTheme);
        }

        if (result.Value.Language != previousLanguage)
        {
            await AnalyticsService.TrackLanguageChangedAsync(previousLanguage, result.Value.Language);
            await LanguageService.SetAppLanguageAsync(result.Value.Language);
            NavigationManager.NavigateTo(NavigationManager.Uri, true);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnImportClick()
    {
        var result = await ImportDialog.ShowAsync(DialogService);
        if (result.IsCancelled || result.IsFailure)
        {
            return;
        }

        _dropZoneContainerLoading = true;
        await ImportService.ApplyAppStateAsync(result.Value);
        await RestoreStateAsync();
        _dropZoneContainerLoading = false;
    }

    private async Task RestoreStateAsync()
    {
        var faculties = await UniversityService.GetFacultiesWithProgramsAsync();
        var programAbbreviation = await LocalStorageService.LoadProgramAbbreviation();
        var specialization = await LocalStorageService.LoadProgramSpecialization();

        if (faculties.IsSuccess && !string.IsNullOrEmpty(programAbbreviation))
        {
            var program = faculties.Value.SelectMany(f => f.Programs).FirstOrDefault(p => p.Abbreviation == programAbbreviation && p.Specialization == specialization);
            if (program != null)
            {
                _selectedProgram = program;
                await UpdateStudyContextAsync(program, true);
                await LoadData(program, true);
            }
        }

        var studyYears = await LocalStorageService.LoadStudyYears();
        _studyContext.Years = studyYears ?? _studyContext.Years;
        _recognizedYear = await LocalStorageService.LoadRecognizedYear();
    }

    private async Task SyncSubjectsFromStorage()
    {
        foreach (var subject in _availableSubjects.Values) subject.Selected = false;

        var storedSubjects = await LocalStorageService.LoadSubjectsAsync();
        var selected = new List<SubjectEntry>();
        foreach (var storageItem in storedSubjects)
        {
            if (!_availableSubjects.TryGetValue(new SubjectEntryKey(storageItem.SubjectId, 1), out var subject))
            {
                continue;
            }

            var updatedEntry = SubjectStorageMapper.AplyStorageData(storageItem, subject);
            selected.Add(updatedEntry);
        }

        var customSubjects = await LocalStorageService.LoadCustomSubjectsAsync();
        selected.AddRange(customSubjects);
        PlanService.SetSubjects(selected);
    }

    private async Task OnShareClick() => await ShareDialog.ShowAsync(DialogService);

    private async Task OnWhatsNewClick()
    {
        await AnalyticsService.TrackWhatsNewOpenedAsync();
        await WhatsNewDialog.ShowAsync(DialogService);
    }

    private void ToggleExpansionPanels(bool open)
    {
        if (open)
        {
            return;
        }

        _studyProgramExpanded = false;
        _compulsoryExpanded = false;
        _compulsoryElectiveExpanded = false;
        _electiveExpanded = false;
        _sportExpanded = false;
    }
}
