@page "/"
@using RISOS.Enums
@using RISOS.Extensions
@using RISOS.Helpers
@using RISOS.Localization
@using RISOS.Mappers
@using RISOS.Pages.Home.Components
@using RISOS.Pages.Home.Dialogs.ImportDialog
@using RISOS.Pages.Home.Dialogs.SettingsDialog
@using RISOS.Pages.Home.Dialogs.ShareDialog
@using RISOS.Pages.Home.Models
@using RISOS.Services

@inject UniversityService UniversityService
@inject IDialogService DialogService
@inject LanguageService LanguageService
@inject NavigationManager NavigationManager
@inject LocalStorageService LocalStorageService
@inject ExportService ExportService
@inject ImportService ImportService
@inject IJSRuntime Js
@inject ISnackbar Snackbar
@inject ThemeStateService ThemeStateService

<style>
    :root {
        --dropzone-height: 250px;
    }

    .side-bar .mud-expand-panel {
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
    }

    .mud-drawer.mud-drawer-mini.mud-drawer-pos-left.mud-drawer--open ~ div:not(.mud-main-content), .mud-drawer.mud-drawer-persistent.mud-drawer-pos-left.mud-drawer--open ~ div:not(.mud-main-content) {
        margin-left: 0 !important;
    }

    .mud-drawer.mud-drawer-mini.mud-drawer-pos-left.mud-drawer--closed ~ div:not(.mud-main-content) {
        margin-left: 0 !important;
    }

    .mud-expand-panel-header {
        padding-left: 16px !important;
        padding-right: 16px !important;
    }

    .mud-collapse-entering .mud-expand-panel-content[hidden],
    .mud-collapse-exiting .mud-expand-panel-content[hidden],
    .mud-collapse-entering .mud-expand-panel-content,
    .mud-collapse-exiting .mud-expand-panel-content {
        display: block !important;
        visibility: visible !important;
    }

    .mud-collapse-wrapper {
        overflow: hidden !important;
    }

    .mud-expand-panel-content {
        padding: 0 8px 8px 8px !important;
    }

    .mud-list-item-multiselect-extended {
        padding: 0 0 0 12px !important;
    }

    .side-bar .mud-expand-panel-header .mud-chip:not(.mud-chip-color-error):not(.mud-chip-color-secondary):not(.mud-chip-color-tertiary) {
        color: var(--mud-palette-text-primary) !important;
        border-color: var(--mud-palette-text-secondary) !important;
    }

    .side-bar .mud-expand-panel-header .mud-badge:not(.mud-badge-error):not(.mud-badge-secondary):not(.mud-badge-tertiary) {
        color: var(--mud-palette-text-primary) !important;
        border-color: var(--mud-palette-text-secondary) !important;
    }

</style>

<SideBar Class="side-bar">
    <OpenedDrawerContent>
        <MudExpansionPanels Elevation="3" Style="height: calc(100vh - 128px); overflow: hidden">
            <MudExpansionPanel Text="@LanguageHelper.StudyProgram" Gutters="false">
                <StudyProgramSelector SelectedProgram="@_selectedProgram"
                                      SelectedProgramChanged="@OnSelectedProgramsChanged" Loading="@_isLoading"/>
            </MudExpansionPanel>
            <SubjectsPanel TGroupKey="int"
                           HeaderTemplate="@(x => $"{x}. {LanguageHelper.Semester}")"
                           GroupBy="@(x => x.Subject.MinSemester)"
                           SubjectChanged="@SubjectChanged"
                           Title="@LanguageHelper.Compulsory"
                           Disabled="@Disabled"
                           Subjects="@CompulsorySubjects"
                           IsLoading="@_isLoading"
                           FixedPixels="326"
                           ReadOnly/>
            <SubjectsPanel TGroupKey="string"
                           GroupBy="@(x => x.Subject.GroupId!)"
                           SubjectChanged="@SubjectChanged"
                           Title="@LanguageHelper.CompulsoryElective"
                           Disabled="@Disabled"
                           Subjects="@CompulsoryElectiveSubjects"
                           IsLoading="@_isLoading"
                           FixedPixels="326"
                           CompulsoryGroups/>
            <SubjectsPanel TGroupKey="SemesterSeason"
                           GroupBy="@(x => x.Subject.SemesterSeason)"
                           HeaderTemplate="@(x => x.ToLabel())"
                           SubjectChanged="@SubjectChanged"
                           Title="@LanguageHelper.Elective"
                           Disabled="@Disabled"
                           Subjects="@ElectiveSubjects"
                           IsLoading="@_isLoading"
                           FixedPixels="310"/>
        </MudExpansionPanels>
    </OpenedDrawerContent>
    <AlwaysVisible>
        <MudStack Row Justify="Justify.Center" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap"
                  Class="px-2 pb-2" Style="width: 100%">
            <MudTooltip Text="@LanguageHelper.Settings">
                <MudIconButton Icon="@Icons.Material.Filled.Settings" Style="color: var(--mud-palette-drawer-text)"
                               OnClick="@OnSettingsClick"/>
            </MudTooltip>
            <MudTooltip Text="@LanguageHelper.Export">
                <MudIconButton
                    Icon="@Icons.Material.Filled.Download"
                    Style="color: var(--mud-palette-drawer-text)"
                    OnClick="@ExportService.HandleExportAsync"/>
            </MudTooltip>
            <MudTooltip Text="@LanguageHelper.Import">
                <MudIconButton
                    Icon="@Icons.Material.Filled.Upload"
                    Style="color: var(--mud-palette-drawer-text)"
                    OnClick="@OnImportClick"/>
            </MudTooltip>
            <MudTooltip Text="@LanguageHelper.Share">
                <MudIconButton
                    Icon="@Icons.Material.Filled.Share"
                    Style="color: var(--mud-palette-drawer-text)"
                    OnClick="@OnShareClick"/>
            </MudTooltip>
        </MudStack>
    </AlwaysVisible>
</SideBar>

<CascadingValue Value="_studyContext">
    <StudiumDropContainer @ref="_dropContainer" Subjects="_selectedSubjects" OnRemove="OnRemove"
                          RecognizedYear="_recognizedYear" LocalStorageLoading="_dropZoneContainerLoading"/>
</CascadingValue>

@code {
    private Dictionary<SubjectEntryKey, SubjectEntry> _subjects = [];
    private StudyProgram? _selectedProgram;

    private bool _isLoading;
    private bool _dropZoneContainerLoading;
    private bool _recognizedYear;
    private StudiumDropContainer _dropContainer = null!;

    private readonly StudyContext _studyContext = new();

    private Dictionary<SubjectEntryKey, SubjectEntry> CompulsorySubjects => _subjects.Where(s => s.Value.Subject.Type == SubjectType.Compulsory && !s.Value.IsCustomSubject).ToDictionary();
    private Dictionary<SubjectEntryKey, SubjectEntry> CompulsoryElectiveSubjects => _subjects.Where(s => s.Value.Subject.Type == SubjectType.CompulsoryElective && !s.Value.IsCustomSubject).ToDictionary();
    private Dictionary<SubjectEntryKey, SubjectEntry> ElectiveSubjects => _subjects.Where(s => s.Value.Subject.Type == SubjectType.Elective && !s.Value.IsCustomSubject).ToDictionary();
    private List<SubjectEntry> _selectedSubjects = [];
    private bool Disabled => _selectedProgram is null;

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(NavigationManager.Uri);

        if (!string.IsNullOrEmpty(uri.Fragment) && uri.Fragment.Length > 1)
        {
            var encodedData = uri.Fragment[1..];

            try
            {
                var appState = AppStateEncoder.Decode<AppState>(encodedData);
                if (appState is not null)
                {
                    await ImportService.ApplyAppStateAsync(appState);
                }

                NavigationManager.NavigateTo(uri.GetLeftPart(UriPartial.Path), replace: true);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Failed to load state from URL: {ex.Message}");
            }
        }

        await base.OnInitializedAsync();
    }

    private async Task LoadData(StudyProgram studyProgram, bool fromStorage)
    {
        _isLoading = true;
        await InvokeAsync(StateHasChanged);

        var result = await UniversityService.GetSubjectsAsync(studyProgram);
        if (result.IsSuccess)
        {
            _subjects = result.Value.Select(s => new SubjectEntry(s)).ToDictionary(x => x.Key);
            if (!fromStorage)
            {
                _selectedSubjects = _subjects.Values.Where(x => x.Selected).ToList();
                var groupedBySemester = _selectedSubjects.GroupBy(x => x.Semester);
                foreach (var semesterGroup in groupedBySemester)
                {
                    var currentIndex = 0;
                    foreach (var subject in semesterGroup)
                    {
                        subject.IndexInZone = currentIndex;
                        currentIndex++;
                    }
                }

                await LocalStorageService.SaveSubjects(SubjectStorageMapper.ToStorageList(_selectedSubjects));
            }
            else
            {
                await SyncSubjectsFromStorage();
            }
        }

        var creditOverride = await LocalStorageService.LoadCreditOverride();
        if (creditOverride.HasValue)
        {
            _studyContext.CreditOverride = creditOverride.Value;
        }

        _recognizedYear = await LocalStorageService.LoadRecognizedYear();

        _selectedSubjects = _selectedSubjects
            .OrderBy(x => x.Semester)
            .ThenBy(x => x.IndexInZone)
            .ToList();

        _isLoading = false;
        await InvokeAsync(StateHasChanged);
        _dropContainer.Refresh();
    }

    private async Task OnSelectedProgramsChanged(StudyProgram? program)
    {
        _dropZoneContainerLoading = true;
        await InvokeAsync(StateHasChanged);

        _selectedProgram = program;

        var savedAbbreviation = await LocalStorageService.LoadProgramAbbreviation();
        var savedSpecialization = await LocalStorageService.LoadProgramSpecialization();

        var isSameProgram = program?.Abbreviation == savedAbbreviation && program?.Specialization == savedSpecialization;
        if (isSameProgram)
        {
            var savedYears = await LocalStorageService.LoadStudyYears();
            _studyContext.Years = savedYears ?? (int)Math.Ceiling(_selectedProgram?.StudyDuration ?? 3.0);
        }
        else
        {
            _studyContext.Years = (int)Math.Ceiling(_selectedProgram?.StudyDuration ?? 3.0);
            await LocalStorageService.SaveStudyYears(_studyContext.Years);
        }

        await LocalStorageService.SaveProgramAbbreviation(program?.Abbreviation);
        await LocalStorageService.SaveProgramSpecialization(program?.Specialization);

        _studyContext.RequiredCredits = _selectedProgram?.Credits ?? 0;
        _studyContext.CreditsWarn = _selectedProgram?.CreditsWarn ?? true;


        if (_selectedProgram is null)
        {
            _subjects.Clear();
            _selectedSubjects.Clear();
            await LocalStorageService.ResetSubjectsAsync();
        }
        else
        {
            await LoadData(_selectedProgram, isSameProgram);
        }

        _dropZoneContainerLoading = false;
        await InvokeAsync(StateHasChanged);
        StateHasChanged();
    }

    private async Task OnRemove(SubjectEntry entry)
    {
        entry.Selected = false;
        var affectedZones = new HashSet<string>();

        if (entry.Attempt != 1)
        {
            affectedZones.Add(entry.Semester);
            _selectedSubjects.Remove(entry);

            var latestAttempt = _selectedSubjects.FirstOrDefault(x => x.Subject.Id == entry.Subject.Id && x.Attempt == entry.Attempt - 1);
            if (latestAttempt is not null)
            {
                latestAttempt.LatestAttempt = true;
                await LocalStorageService.UpdateSubjectAsync(latestAttempt);
            }
        }
        else
        {
            var itemsToRemove = _selectedSubjects.Where(x => x.Subject.Id == entry.Subject.Id);
            foreach (var item in itemsToRemove)
            {
                affectedZones.Add(item.Semester);
            }

            _selectedSubjects.RemoveAll(x => x.Subject.Id == entry.Subject.Id);
        }

        await LocalStorageService.RemoveSubjectAsync(entry.Key);

        foreach (var zone in affectedZones)
        {
            await FixZoneIndexesAsync(zone);
        }

        _dropContainer.Refresh();
    }

    private async Task SubjectChanged(SubjectEntry subject)
    {
        _subjects[subject.Key] = subject;

        if (subject.Selected)
        {
            subject.IndexInZone = _selectedSubjects.Count(x => x.Semester == subject.Semester);
            _selectedSubjects.Add(subject);
            await LocalStorageService.UpdateSubjectAsync(subject);
        }
        else
        {
            subject.LatestAttempt = true;
            var affectedZones = _selectedSubjects
                .Where(s => s.Subject.Id == subject.Subject.Id)
                .Select(s => s.Semester)
                .Distinct()
                .ToList();

            _selectedSubjects.RemoveAll(s => s.Subject.Id == subject.Subject.Id);
            await LocalStorageService.RemoveSubjectAsync(subject.Key);
            foreach (var zone in affectedZones)
            {
                await FixZoneIndexesAsync(zone);
            }
        }

        _dropContainer.Refresh();
    }

    private async Task OnSettingsClick()
    {
        var result = await SettingsDialog.ShowAsync(DialogService, _studyContext);
        if (result.IsCancelled || result.IsFailure)
        {
            return;
        }

        _studyContext.CreditOverride = result.Value.Credits;
        await LocalStorageService.SaveCreditOverride(result.Value.Credits);
        await ThemeStateService.SetThemeType(result.Value.SelectedTheme);

        var language = await LanguageService.GetAppLanguageAsync();
        if (result.Value.Language != language)
        {
            await LanguageService.SetAppLanguageAsync(result.Value.Language);
            NavigationManager.NavigateTo(NavigationManager.Uri, true);
        }

        StateHasChanged();
    }

    private async Task OnImportClick()
    {
        var result = await ImportDialog.ShowAsync(DialogService);
        if (result.IsCancelled || result.IsFailure)
        {
            return;
        }

        _dropZoneContainerLoading = true;
        await ImportService.ApplyAppStateAsync(result.Value);
        var faculties = await UniversityService.GetFacultiesWithProgramsAsync();

        var programAbbreviation = await LocalStorageService.LoadProgramAbbreviation();
        var specialization = await LocalStorageService.LoadProgramSpecialization();
        if (!string.IsNullOrEmpty(programAbbreviation))
        {
            var program = faculties.Value
                .SelectMany(f => f.Programs)
                .FirstOrDefault(p =>
                    p.Abbreviation == programAbbreviation &&
                    p.Specialization == specialization);
            if (program != null)
            {
                _selectedProgram = program;
                await LoadData(program, true);
            }
        }

        var studyYears = await LocalStorageService.LoadStudyYears();
        _studyContext.Years = studyYears ?? _studyContext.Years;
        _recognizedYear = await LocalStorageService.LoadRecognizedYear();
        _dropZoneContainerLoading = false;
    }

    private async Task FixZoneIndexesAsync(string semesterZone)
    {
        var remainingItems = _selectedSubjects
            .Where(x => x.Semester == semesterZone)
            .OrderBy(x => x.IndexInZone)
            .ToList();

        for (var i = 0; i < remainingItems.Count; i++)
        {
            if (remainingItems[i].IndexInZone == i)
            {
                continue;
            }

            remainingItems[i].IndexInZone = i;
            await LocalStorageService.UpdateSubjectAsync(remainingItems[i]);
        }
    }

    private async Task SyncSubjectsFromStorage()
    {
        _selectedSubjects.Clear();
        foreach (var subject in _subjects.Values)
        {
            subject.Selected = false;
        }

        var storedSubjects = await LocalStorageService.LoadSubjectsAsync();

        foreach (var storageItem in storedSubjects)
        {
            if (!_subjects.TryGetValue(new SubjectEntryKey(storageItem.SubjectId, 1), out var subject))
            {
                continue;
            }

            var updatedEntry = SubjectStorageMapper.ToSubjectEntry(storageItem, subject);
            _selectedSubjects.Add(updatedEntry);
        }

        var customSubjects = await LocalStorageService.LoadCustomSubjectsAsync();
        _selectedSubjects.AddRange(customSubjects);
    }

    private async Task OnShareClick() => await ShareDialog.ShowAsync(DialogService);
}
