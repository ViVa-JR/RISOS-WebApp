@using RISOS.Common.Components
@using RISOS.Enums
@using RISOS.Extensions
@using RISOS.Localization
@using RISOS.Models
@using RISOS.Pages.Home.Models

<RDialog TReturn="SubjectEntry"
         Title="@LanguageHelper.AddCustomSubject"
         SubmitText="@LanguageHelper.Add"
         SubmitIcon="@Icons.Material.Filled.Add"
         OnSubmit="@OnSubmit">
    <MudGrid Spacing="3">
        <MudItem xs="12">
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="font-weight-bold mb-n2">
                @LanguageHelper.BasicInformation
            </MudText>
        </MudItem>
        <MudItem xs="12" md="8">
            <MudTextField @bind-Value="_model.Name" Label="@LanguageHelper.Name" Required="true" RequiredError="@($"{LanguageHelper.Name} {LanguageHelper.IsRequired_y}")" Variant="Variant.Outlined" Placeholder="@LanguageHelper.IMA"/>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="_model.ShortName" Label="@LanguageHelper.Abbreviation" Required="true" RequiredError="@($"{LanguageHelper.Abbreviation} {LanguageHelper.IsRequired_a}")"  MaxLength="10" Variant="Variant.Outlined"
                          Placeholder="@LanguageHelper.IMAAbbreviation" Class="hlinena-rapuje"/>
        </MudItem>

        <MudItem xs="12">
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mt-2 font-weight-bold mb-n2">
                @LanguageHelper.AcademicDetails
            </MudText>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudNumericField @bind-Value="_model.Credits" Label="@LanguageHelper.Credits_y" Min="0" Required="true" Variant="Variant.Outlined" Adornment="Adornment.End" AdornmentText="cr"/>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudNumericField @bind-Value="_model.MinSemester" Label="@LanguageHelper.MinimumSemester" Min="1" Required="true" Variant="Variant.Outlined" HelperText="@LanguageHelper.MinSemesterHelperText"/>
        </MudItem>

        <MudItem xs="12">
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mt-2 font-weight-bold mb-n2">@LanguageHelper.Classification</MudText>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect T="SubjectType" Label="@LanguageHelper.SubjectType" @bind-Value="@_model.Type" @bind-Value:after="OnTypeChanged" Required="true" Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter">
                @foreach (var type in Enum.GetValues<SubjectType>())
                {
                    <MudSelectItem Value="@type">@type.ToLabel()</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudTextField @ref="_groupIdField"
                          @bind-Value="_model.GroupId"
                          Label="@LanguageHelper.Group"
                          Disabled="@(_model.Type != SubjectType.CompulsoryElective)"
                          Required="@(_model.Type == SubjectType.CompulsoryElective)"
                          RequiredError="@($"{LanguageHelper.Group} {LanguageHelper.IsRequired_a}")"
                          Variant="Variant.Outlined"
                          Placeholder="@(_model.Type == SubjectType.CompulsoryElective ? "e.g. PV, A, B" : LanguageHelper.NotApplicable)"/>
        </MudItem>
        <MudItem xs="12" sm="8">
            <MudSelect T="CompletionType" Label="@LanguageHelper.CompletionType" @bind-Value="_model.CompletionType" Required="true" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                @foreach (var comp in Enum.GetValues<CompletionType>())
                {
                    <MudSelectItem Value="@comp">@comp.GetDescription()</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudSelect T="SemesterSeason" Label="@LanguageHelper.SemesterSeason" @bind-Value="_model.SemesterSeason" Required="true" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
                @foreach (var season in Enum.GetValues<SemesterSeason>())
                {
                    <MudSelectItem Value="@season">@season.ToLabel()</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>
</RDialog>

@code {
    private MudTextField<string> _groupIdField = null!;
    private AddCustomSubjectModel _model = new();

    private async Task OnTypeChanged()
    {
        if (_model.Type == SubjectType.CompulsoryElective)
        {
            return;
        }

        _model.GroupId = null;
        await _groupIdField.ResetValidationAsync();
    }

    private Task<SubjectEntry> OnSubmit()
    {
        return Task.FromResult(_model.ToSubjectEntry());
    }

    public static async Task<DialogResult<SubjectEntry>> ShowAsync(IDialogService dialogService)
    {
        var dialog = await dialogService.ShowAsync<AddCustomSubjectDialog>(string.Empty, new DialogOptions
        {
            FullWidth = true
        });
        return await dialog.GetResultAsync<SubjectEntry>();
    }

}