@using System.Text.Json
@using RISOS.Common.Components
@using RISOS.Common.Models
@using RISOS.Extensions
@using RISOS.Localization
@using RISOS.Services

@inject ISnackbar Snackbar

<RDialog TReturn="AppState"
         Title="@LanguageHelper.ImportJSON"
         SubmitText="@LanguageHelper.Import"
         SubmitIcon="@Icons.Material.Filled.Upload"
         OnSubmit="@OnSubmit"
         OnValidateFunc="Validate"
         HeaderIcon="@Icons.Material.Filled.CloudUpload">
    <MudStack Style="width: 100%; min-width: 400px">
        <MudFileUpload T="IBrowserFile"
                       FilesChanged="@OnFilesChanged"
                       AppendMultipleFiles="false"
                       DragAndDrop="true"
                       Accept=".json"
                       tabindex="-1"
                       Style="cursor: pointer;"
                       Class="overflow-hidden z-20 mt-n6"
                       @bind-Dragging="@_dragging"
                       @bind-Dragging:after="@ClearDragClass">
            <CustomContent>
                <MudPaper Height="200px"
                          Outlined="true"
                          @onclick="@context.OpenFilePickerAsync"
                          @ondragenter="@SetDragClass"
                          Class="@_dragClass">
                    <MudStack Class="w-100 h-100" AlignItems="AlignItems.Center" Justify="Justify.Center">
                        @if (_selectedFile == null)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Large" Color="Color.Primary"/>
                        }
                        else
                        {
                            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Close" Color="Color.Error"
                                           Style="position: absolute; top: 8px; right: 8px" OnClick="@ClearFile"/>
                            <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" Color="Color.Primary"
                                     Size="Size.Large"/>
                        }
                        <MudText Typo="Typo.subtitle1" Class="mt-2">
                            @(_selectedFile == null ? LanguageHelper.DropJSON : _selectedFile.Name)
                        </MudText>
                    </MudStack>
                </MudPaper>
                @if (_isSubmitAttempted && _selectedFile == null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Error" Class="ml-1 mt-1">
                        @LanguageHelper.MissingFile
                    </MudText>
                }
            </CustomContent>
            <SelectedTemplate/>
        </MudFileUpload>
        @if (_importError != null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-2">@_importError</MudAlert>
        }
    </MudStack>
</RDialog>

@code {
    private const string DefaultDragClass = "relative d-flex flex-column p-r gap-2 rounded-lg border-2 border-dashed pa-4 mt-4 mud-width-full mud-height-full";

    private IBrowserFile? _selectedFile;
    private AppState? _validatedData;
    private string? _importError;
    private bool _isSubmitAttempted;

    private string _dragClass = DefaultDragClass;
    private bool _dragging;

    private void SetDragClass()
    {
        _dragClass = $"{DefaultDragClass} mud-border-success";
        _dragging = true;
    }

    private void ClearDragClass()
    {
        if (!_dragging)
        {
            _dragClass = DefaultDragClass;
        }
    }

    private async Task OnFilesChanged(IBrowserFile? file)
    {
        _dragClass = DefaultDragClass;
        _importError = null;

        if (file == null)
        {
            return;
        }

        try
        {
            if (!file.Name.EndsWith(".json"))
            {
                _importError = LanguageHelper.InvalidFormat;
                _selectedFile = null;
                return;
            }

            await using var stream = file.OpenReadStream(2048000);
            using var reader = new StreamReader(stream);
            var content = await reader.ReadToEndAsync();

            _validatedData = JsonSerializer.Deserialize<AppState>(content);

            if (_validatedData != null)
            {
                _isSubmitAttempted = false;
                _selectedFile = file;
                Snackbar.Add(LanguageHelper.FileVerified, Severity.Success);
            }
        }
        catch (Exception)
        {
            _importError = LanguageHelper.FileInvalid;
            _selectedFile = null;
        }
    }

    private async Task <Result> Validate()
    {
        if (_validatedData != null)
        {
            return Result.Success();
        }

        _isSubmitAttempted = true;
        _dragClass = $"{DefaultDragClass} mud-border-error";
        StateHasChanged();
        return Result.Failure(Error.NullValue);
    }

    private void ClearFile()
    {
        _selectedFile = null;
        _validatedData = null;
        _importError = null;
        _isSubmitAttempted = false;
    }

    private Task<AppState?> OnSubmit() => Task.FromResult(_validatedData);

    public static async Task<DialogResult<AppState>> ShowAsync(IDialogService dialogService)
    {
        var dialog = await dialogService.ShowAsync<ImportDialog>(string.Empty, new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium
        });
        return await dialog.GetResultAsync<AppState>();
    }
}
