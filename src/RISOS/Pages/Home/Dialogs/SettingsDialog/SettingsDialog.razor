@using RISOS.Common.Flags
@using RISOS.Common.Models
@using RISOS.Enums
@using RISOS.Extensions
@using RISOS.Localization
@using RISOS.Pages.Home.Models
@using RISOS.Services

@inject LanguageService LanguageService
@inject GitRepositoryInfoService GitRepositoryInfoService
@inject NavigationManager NavigationManager
@inject LocalStorageService LocalStorageService
@inject ThemeStateService ThemeService
@inject ThemePreviewService ThemePreviewService

<RDialog TReturn="SettingsDialogModel"
         Title="@LanguageHelper.SettingsDialog_Title"
         SubmitIcon="@Icons.Material.Filled.Save"
         SubmitText="@LanguageHelper.Save"
         SubmitDisabled="@(!HasChanges)"
         OnSubmit="@OnSubmit">
    <HeaderRight>
        @if (!IsReadOnly)
        {
            <MudTooltip Text="@LanguageHelper.ClearStorage">
                <MudIconButton Icon="@Icons.Material.Outlined.DeleteSweep" OnClick="@ClearData"/>
            </MudTooltip>
        }
    </HeaderRight>
    <ChildContent>
        <ContentOrCircularLoading IsLoading="_loading">
            <MudStack Spacing="4" Class="pb-1">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">
                        <b>@LanguageHelper.SettingsDialog_Language</b>
                    </MudText>

                    <MudToggleGroup T="AppLanguage" @bind-Value="_model.Language" Color="Color.Primary"
                                    SelectionMode="SelectionMode.SingleSelection" Class="w-100">
                        <MudToggleItem Value="AppLanguage.Czech">
                            <div class="d-flex align-center gap-2 pa-1">
                                <CzechFlag Style="width: 40px; border-radius: 2px;"/>
                                <MudText Typo="Typo.body2">@LanguageHelper.Language_Czech</MudText>
                            </div>
                        </MudToggleItem>
                        <MudToggleItem Value="AppLanguage.English">
                            <div class="d-flex align-center gap-2 pa-1">
                                <EnglishFlag Style="width: 40px; border-radius: 2px;"/>
                                <MudText Typo="Typo.body2">@LanguageHelper.Language_English</MudText>
                            </div>
                        </MudToggleItem>
                    </MudToggleGroup>

                    @if (LanguageChanged)
                    {
                        <MudAlert Variant="Variant.Outlined" Severity="Severity.Info" Dense>
                            @LanguageHelper.LanguageAlert
                        </MudAlert>
                    }
                </MudStack>

                <MudDivider/>

                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">
                        <b>@LanguageHelper.Themes</b>
                    </MudText>
                    <MudGrid Spacing="2" Class="mt-2">
                        @foreach (var theme in Enum.GetValues<ThemeType>())
                        {
                            var isSelected = _model.SelectedTheme == theme;
                            <MudItem xs="6" sm="4">
                                <MudPaper Elevation="@(isSelected ? 4 : 1)"
                                          Class="pa-2 cursor-pointer transition-transform hover-scale"
                                          Style="@($"width: 100%; border-radius: 8px; border: 2px solid {(isSelected ? "var(--mud-palette-primary)" : "transparent")};")"
                                          @onclick="() => SelectTheme(theme)">
                                    <MudStack Spacing="2" AlignItems="AlignItems.Center">
                                        <div class="d-flex justify-center align-center overflow-hidden" style="width: 100%; height: 80px;">
                                            @if (_svgPreviews.TryGetValue(theme, out var svgContent))
                                            {
                                                @((MarkupString)svgContent)
                                            }
                                            else
                                            {
                                                <MudProgressCircular Size="Size.Small" Color="Color.Default" Indeterminate="true"/>
                                            }
                                        </div>
                                        <MudText Typo="Typo.caption" Align="Align.Center">
                                            <b>@GetThemeLabel(theme)</b>
                                        </MudText>
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                </MudStack>

                @if (!IsReadOnly)
                {
                    <MudDivider/>

                    <MudStack Spacing="2">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">
                            <b>@LanguageHelper.SettingsDialog_AcademicSettings</b>
                        </MudText>

                        <MudStack Spacing="2">
                            <MudSwitch T="bool"
                                       Value="_overrideCredits"
                                       ValueChanged="OnOverrideToggled"
                                       Color="Color.Primary"
                                       Label="@LanguageHelper.SettingsDialog_OverrideCredits"/>
                            <MudNumericField T="int?"
                                             @bind-Value="_model.Credits"
                                             Disabled="@(!_overrideCredits)"
                                             Label="@LanguageHelper.SettingsDialog_RequiredCredits"
                                             Variant="Variant.Outlined"
                                             Min="0"
                                             Adornment="Adornment.End"
                                             AdornmentText="@LanguageHelper.Cr"/>
                        </MudStack>
                    </MudStack>
                }

                <MudDivider/>

                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">
                        <b>@LanguageHelper.Contact</b>
                    </MudText>

                    <MudStack Spacing="@(IsReadOnly ? 1 : 5)" Row AlignItems="AlignItems.Center" Justify="Justify.Center" Wrap="@Wrap.Wrap">
                        <MudButton Href="https://github.com/ViVa-JR/RISOS/issues/new/choose"
                                   Target="_blank"
                                   StartIcon="@Icons.Custom.Brands.GitHub"
                                   Variant="Variant.Text"
                                   Color="Color.Default">
                            @LanguageHelper.ReportBug
                        </MudButton>
                        <MudButton Href="@MailToUri"
                                   Target="_blank"
                                   StartIcon="@Icons.Material.Filled.Email"
                                   Variant="Variant.Text"
                                   Color="Color.Default">
                            @LanguageHelper.Email
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudStack>
        </ContentOrCircularLoading>
    </ChildContent>
    <FooterLeft>
        @if (!IsReadOnly)
        {
            <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-disabled);">
                @(LanguageHelper.LastDataUpdate + ": " + _dateTime)
            </MudText>
        }
    </FooterLeft>
</RDialog>

@code {
    [Parameter]
    public required StudyContext StudyContext { get; set; }

    [Parameter]
    public bool IsReadOnly { get; set; }

    private bool _loading = true;
    private SettingsDialogModel _model = new();
    private bool _overrideCredits;
    private AppLanguage _originalLanguage;
    private DateTime? _dateTime;

    private bool LanguageChanged => _model.Language != _originalLanguage;
    private bool ThemeChanged => _model.SelectedTheme != (ThemeService.CurrentThemeType ?? ThemeType.Default);
    private bool CreditsChanged => _overrideCredits != StudyContext.CreditOverride.HasValue || (_overrideCredits && _model.Credits != StudyContext.CreditOverride);
    private bool HasChanges => LanguageChanged || ThemeChanged || CreditsChanged;
    private static string MailToUri => $"mailto:xsafar26@vutbr.cz?subject={Uri.EscapeDataString(LanguageHelper.EmailSubject)}&body={Uri.EscapeDataString(LanguageHelper.EmailBody)}";

    @code {
        private Dictionary<ThemeType, string> _svgPreviews = new();

        private void SelectTheme(ThemeType theme)
        {
            _model.SelectedTheme = theme;
        }

        private string GetThemeLabel(ThemeType theme)
        {
            return theme switch
            {
                ThemeType.Default => LanguageHelper.Theme_Default,
                ThemeType.Deuteranopia => LanguageHelper.Theme_Deuteranopia,
                ThemeType.Protanopia => LanguageHelper.Theme_Protanopia,
                ThemeType.Tritanopia => LanguageHelper.Theme_Tritanopia,
                ThemeType.HighContrast => LanguageHelper.Theme_HighContrast,
                _ => theme.ToString()
            };
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _model.Language = await LanguageService.GetAppLanguageAsync();
        _model.SelectedTheme = ThemeService.CurrentThemeType ?? ThemeType.Default;
        _model.Credits = StudyContext.CreditOverride;
        _originalLanguage = _model.Language;
        _overrideCredits = StudyContext.CreditOverride.HasValue;

        var result = await GitRepositoryInfoService.GetLastUpdateDateAsync();
        if (result.IsSuccess)
        {
            _dateTime = result.Value;
        }

        foreach (var theme in Enum.GetValues<ThemeType>())
        {
            var svg = await ThemePreviewService.GetPreviewSvgAsync(theme);
            _svgPreviews[theme] = svg;
        }

        _loading = false;
        await InvokeAsync(StateHasChanged);
        await base.OnInitializedAsync();
    }

    private void OnOverrideToggled(bool isToggled)
    {
        _overrideCredits = isToggled;
        if (!isToggled)
        {
            _model.Credits = null;
        }
    }

    private Task<SettingsDialogModel> OnSubmit()
    {
        if (!_overrideCredits)
        {
            _model.Credits = null;
        }

        return Task.FromResult(_model);
    }

    private async Task ClearData()
    {
        await LocalStorageService.ClearAppStateAsync();
        NavigationManager.NavigateTo(NavigationManager.Uri, true);
    }

    public static async Task<DialogResult<SettingsDialogModel>> ShowAsync(IDialogService dialogService, StudyContext studyContext, bool isReadOnly = false)
    {
        var dialog = await dialogService.ShowAsync<SettingsDialog>(string.Empty, new DialogParameters<SettingsDialog>
        {
            { x => x.StudyContext, studyContext },
            { x => x.IsReadOnly, isReadOnly }
        }, new DialogOptions
        {
            FullWidth = true,
            MaxWidth = MaxWidth.Small
        });
        return await dialog.GetResultAsync<SettingsDialogModel>();
    }
}
