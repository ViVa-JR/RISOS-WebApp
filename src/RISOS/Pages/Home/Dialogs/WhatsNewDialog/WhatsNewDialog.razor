@using RISOS.Localization

<RDialog Title="@LanguageHelper.WhatsNew" HeaderIcon="@Icons.Material.Filled.Info" OnlyClosable TReturn="bool">
    <HeaderRight></HeaderRight>
    <ChildContent>
        <MudStack Spacing="4" Class="pb-2">
            <MudText Typo="Typo.subtitle2" Color="Color.Primary">
                <b>@LanguageHelper.LatestUpdates</b>
            </MudText>
            
            <MudDivider />
            
            <MudList T="string" Dense="true" Class="pa-0" ReadOnly>
                <MudListItem Text="Global Search (CTRL + F)" Icon="@Icons.Material.Filled.Search" IconColor="Color.Primary"/>
                <MudListItem Text="Semester Quick Actions" Icon="@Icons.Material.Filled.FlashOn" IconColor="Color.Warning"/>
                <MudListItem Text="Sports Tracking" Icon="@Icons.Material.Filled.SportsSoccer" IconColor="Color.Success"/>
                <MudListItem Text="Trash Drop-zone" Icon="@Icons.Material.Filled.DeleteSweep" IconColor="Color.Error"/>
                <MudListItem Text="Mobile Optimized Readonly Layout" Icon="@Icons.Material.Filled.PhoneIphone" IconColor="Color.Default"/>
                <MudListItem Text="Export as Image & JSON" Icon="@Icons.Material.Filled.Download" IconColor="Color.Info"/>
                <MudListItem Text="Theme Customization" Icon="@Icons.Material.Filled.Palette" IconColor="Color.Secondary"/>
                <MudListItem Text="Plan Sharing via Link" Icon="@Icons.Material.Filled.Share" IconColor="Color.Tertiary"/>
                <MudListItem Text="Full Language Support" Icon="@Icons.Material.Filled.Language" IconColor="Color.Primary"/>
                <MudListItem Text="Custom Subject Creation" Icon="@Icons.Material.Filled.AddBox" IconColor="Color.Success"/>
            </MudList>
            
            <MudDivider />
        </MudStack>
    </ChildContent>
</RDialog>

@code {
    public static async Task ShowAsync(IDialogService dialogService)
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        await dialogService.ShowAsync<WhatsNewDialog>("", options);
    }
}
