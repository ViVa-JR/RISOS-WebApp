@using RISOS.Localization

<RDialog Title="@LanguageHelper.WhatsNew" HeaderIcon="@Icons.Material.Filled.Info" OnlyClosable TReturn="bool">
    <HeaderRight></HeaderRight>
    <ChildContent>
        <MudStack Spacing="4" Class="pb-2">
            <MudText Typo="Typo.subtitle2" Color="Color.Primary">
                <b>@LanguageHelper.LatestUpdates</b>
            </MudText>
            
            <MudDivider />
            
            <MudList T="string" Dense="true" Class="pa-0" ReadOnly>
                <MudListItem Text="@LanguageHelper.WhatsNew_GlobalSearch" Icon="@Icons.Material.Filled.Search" IconColor="Color.Primary"/>
                <MudListItem Text="@LanguageHelper.WhatsNew_SemesterQuickActions" Icon="@Icons.Material.Filled.FlashOn" IconColor="Color.Warning"/>
                <MudListItem Text="@LanguageHelper.WhatsNew_SportsTracking" Icon="@Icons.Material.Filled.SportsSoccer" IconColor="Color.Success"/>
                <MudListItem Text="@LanguageHelper.WhatsNew_TrashDropzone" Icon="@Icons.Material.Filled.DeleteSweep" IconColor="Color.Error"/>
                <MudListItem Text="@LanguageHelper.WhatsNew_MobileOptimized" Icon="@Icons.Material.Filled.PhoneIphone" IconColor="Color.Default"/>
                <MudListItem Text="@LanguageHelper.WhatsNew_Export" Icon="@Icons.Material.Filled.Download" IconColor="Color.Info"/>
                <MudListItem Text="@LanguageHelper.WhatsNew_ThemeCustomization" Icon="@Icons.Material.Filled.Palette" IconColor="Color.Secondary"/>
                <MudListItem Text="@LanguageHelper.WhatsNew_PlanSharing" Icon="@Icons.Material.Filled.Share" IconColor="Color.Tertiary"/>
                <MudListItem Text="@LanguageHelper.WhatsNew_FullLanguageSupport" Icon="@Icons.Material.Filled.Language" IconColor="Color.Primary"/>
                <MudListItem Text="@LanguageHelper.WhatsNew_CustomSubjectCreation" Icon="@Icons.Material.Filled.AddBox" IconColor="Color.Success"/>
            </MudList>
            
            <MudDivider />
        </MudStack>
    </ChildContent>
</RDialog>

@code {
    public static async Task ShowAsync(IDialogService dialogService)
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        await dialogService.ShowAsync<WhatsNewDialog>("", options);
    }
}
