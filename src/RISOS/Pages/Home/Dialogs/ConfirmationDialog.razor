@using RISOS.Common.Components
@using RISOS.Common.Models
@using RISOS.Extensions
@using RISOS.Localization

<RDialog TReturn="ReturnValue"
         Title="@LanguageHelper.ConfirmDecrese"
         SubmitIcon="@Icons.Material.Filled.Done"
         SubmitText="@LanguageHelper.Confirm"
         OnSubmit="@OnSubmit">
    <ChildContent>
        <MudText>
            @LanguageHelper.ConfirmDecreseMessage
        </MudText>
    </ChildContent>
</RDialog>

@code {
    private Task<ReturnValue> OnSubmit()
    {
        return Task.FromResult(new ReturnValue());
    }

    public static async Task<DialogResult<ReturnValue>> ShowAsync(IDialogService dialogService)
    {
        var dialog = await dialogService.ShowAsync<ConfirmationDialog>(string.Empty, new DialogOptions
        {
            FullWidth = true,
            MaxWidth = MaxWidth.Small
        });
        return await dialog.GetResultAsync<ReturnValue>();
    }

    public record ReturnValue;
}
