@using RISOS.Common.Models
@using RISOS.Enums
@using RISOS.Extensions
@using RISOS.Localization
@using RISOS.Pages.Home.Dialogs.AddCustomSubjectDialog
@using RISOS.Pages.Home.Models
@using RISOS.Services

@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LocalStorageService LocalStorageService
@inject AnalyticsService AnalyticsService

<style>
    .card-text {
        white-space: nowrap;
        text-overflow: ellipsis;
        overflow: hidden;
    }

    .mud-icon-button:focus-within {
        background: unset !important;
    }

    .mud-overlay .app-title {
        color: var(--mud-palette-primary);
        font-size: 66px;
        letter-spacing: 2px;
        line-height: 1;
    }
</style>

<style>
    .trash-drop-zone {
        opacity: 0;
        width: 0;
        margin-left: 0;
        pointer-events: none;
        transition: opacity 0.2s ease, width 0.2s ease, margin-left 0.2s ease;
        border: 2px dashed var(--mud-palette-error) !important;
        background-color: var(--mud-palette-surface) !important;
    }

    .trash-drop-zone.mud-border-success,
    .trash-drop-zone.mud-border-error {
        opacity: 1;
        width: 120px;
        min-width: 120px;
        margin-left: 12px;
        pointer-events: auto;
    }

    .trash-drop-zone.mud-border-error {
        opacity: 0.4;
        background-color: var(--mud-palette-error-hover) !important;
        border-style: solid !important;
    }

    .trash-drop-zone .trash-disabled-icon,
    .trash-drop-zone .trash-error-text {
        display: none;
    }

    .trash-drop-zone.mud-border-error .trash-icon {
        display: none;
    }

    .trash-drop-zone.mud-border-error .trash-disabled-icon,
    .trash-drop-zone.mud-border-error .trash-error-text {
        display: block;
    }
</style>

<div style="position: relative;">
    <MudOverlay Visible="LocalStorageLoading"
                DarkBackground="true"
                Absolute="true"
                ZIndex="9999">
        <MudStack AlignItems="AlignItems.Center">
            <MudText Class="app-title">
                RISØS
            </MudText>
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large"/>
        </MudStack>
    </MudOverlay>

    <MudDropContainer T="SubjectEntry" @ref="_dropContainer" Items="@Subjects" ItemsSelector="@Selector"
                      ItemDropped="@ItemUpdated"
                      CanDrop="@CanDrop"
                      Class="d-flex flex-column gap-3 mb-2"
                      Style="height: calc(100vh - 20px)"
                      ApplyDropClassesOnDragStarted
                      CanDropClass="mud-alert-text-success mud-border-success"
                      NoDropClass="mud-alert-text-error mud-border-error">
        <ChildContent>
            <MudStack Row Spacing="0" Class="w-100 hide-in-export px-0 px-md-1 pb-1" Style="z-index: 1000; position: relative;">
                <div class="rounded-lg border-2 border-dashed mud-border-lines-default mud-background-gray flex-grow-1 d-flex flex-column"
                     style="max-height: 250px; min-height: 120px;">
                    <MudStack Row Spacing="3" Class="px-4 pt-2 pb-1" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">@LanguageHelper.UnassignedSubjects</MudText>
                        <MudTooltip Text="@LanguageHelper.AddCustomSubject">
                            <MudButton
                                Variant="Variant.Outlined"
                                StartIcon="@Icons.Material.Filled.AddCircleOutline"
                                IconColor="Color.Primary"
                                Color="Color.Primary"
                                OnClick="@OpenAddDialog">
                                @LanguageHelper.Add
                            </MudButton>
                        </MudTooltip>
                        <MudSpacer/>
                        <SubjectTypeLegend Class="hide-in-export"/>
                    </MudStack>
                    <div class="flex-grow-1 overflow-y-auto">
                        <MudDropZone T="SubjectEntry" Identifier="@SubjectEntry.Unassigned"
                                     Class="px-4 pb-4 pt-1 d-flex flex-wrap gap-2 border-transparent"
                                     Style="min-height: 100%;"/>
                    </div>
                </div>

                <MudDropZone T="SubjectEntry" Identifier="Trash"
                             Class="trash-drop-zone rounded-lg d-flex flex-column align-center justify-center">
                    <MudIcon Icon="@Icons.Material.Filled.DeleteForever" Size="Size.Large" Color="Color.Error" Class="trash-icon"/>
                    <MudIcon Icon="@Icons.Material.Filled.Block" Size="Size.Large" Color="Color.Error" Class="trash-disabled-icon"/>
                    <MudText Typo="Typo.caption" Color="Color.Error" Class="trash-error-text mt-1 px-2 text-center" Style="font-weight: bold; line-height: 1.2;">
                        @LanguageHelper.CompulsorySubjectDeleteError
                    </MudText>
                </MudDropZone>
            </MudStack>

            <div id="export-zone" class="d-flex flex-column gap-3 flex-grow-1" style="min-height: 0">
                <ControlCenter RecognizedYear="@RecognizedYear" RecognizedYearChanged="@RecognizedYearChanged" YearsChanged="@OnYearsChanged"
                               TotalCredits="@TotalCredits" NeedConfirmation="@NeedConfirmation"/>

                <div id="main-scroll-container" style="overflow: scroll; position: relative; flex-grow: 1;">

                    <div class="indicator-anchor top">
                        <div class="scroll-indicator top">
                            <MudIcon Icon="@Icons.Material.Filled.KeyboardDoubleArrowUp"/>
                            <MudText Typo="Typo.caption">SCROLL UP</MudText>
                        </div>
                    </div>
                    <MudStack Row Class="mb-3">
                        @foreach (var year in Enumerable.Range(StartYear, Years))
                        {
                            var winterSem = year * 2 - 1;
                            var summerSem = year * 2;

                            <div class="rounded-lg pa-4 d-flex flex-column mt-4"
                                 style="position: relative; border: 2px dotted var(--mud-palette-lines-default); height: 100%; min-width: 336px; flex: 1;">
                                <div
                                    style="position: absolute; top: -16px; left: 16px; background-color: var(--mud-palette-background); padding: 0 16px; white-space: nowrap; z-index: 10;">
                                    <MudText Typo="Typo.h6" Color="Color.Primary"
                                             Class="font-weight-bold">@(year == 0 ? LanguageHelper.RecognizedYearTitle : $"{year}. {LanguageHelper.Years_One}")</MudText>
                                </div>

                                <MudStack Class="flex-grow-1">
                                    <SemesterDropZone Semester="@winterSem" Credits="@GetSemesterCredits(winterSem)"
                                                      SemesterSeason="SemesterSeason.Winter"
                                                      CompleteSemester="@OnCompleteSemester"/>
                                    <SemesterDropZone Semester="@summerSem" Credits="@GetSemesterCredits(summerSem)"
                                                      SemesterSeason="SemesterSeason.Summer"
                                                      CompleteSemester="@OnCompleteSemester"/>
                                </MudStack>
                                <MudStack AlignItems="AlignItems.Center" Row StretchItems="StretchItems.Start" Spacing="1" Class="pt-2">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Default">@LanguageHelper.YearTotal</MudText>

                                    @{
                                        var yearCredits = GetYearCredits(year);
                                    }

                                    @if (yearCredits.Completed > 0)
                                    {
                                        <MudText Typo="Typo.body1" Color="Color.Success">@yearCredits.Completed</MudText>
                                        <MudText Typo="Typo.body1" Color="Color.Primary">/</MudText>
                                    }
                                    <MudText Typo="Typo.body1" Color="Color.Primary">
                                        <b>@yearCredits.Registered</b> @LanguageHelper.Credits
                                    </MudText>
                                </MudStack>
                            </div>
                        }
                    </MudStack>

                    <div class="indicator-anchor bottom">
                        <div class="scroll-indicator bottom">
                            <MudText Typo="Typo.caption">SCROLL DOWN</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.KeyboardDoubleArrowDown"/>
                        </div>
                    </div>
                </div>
            </div>
        </ChildContent>
        <ItemRenderer>
            <SemesterDropZoneItemTemplate Entry="context"
                                          EntryChanged="@EntryChanged"
                                          SemesterCount="@(StudyContext.Years * 2)"
                                          RecognizedYear="@RecognizedYear"
                                          RemoveEntry="@OnRemove"
                                          AddEntry="@AddSubjectAsync"
                                          RetakeEntry="@RetakeSubject"/>
        </ItemRenderer>
    </MudDropContainer>
</div>

@code {
    [CascadingParameter]
    public required StudyContext StudyContext { get; set; }

    [Parameter]
    public List<SubjectEntry> Subjects { get; set; } = [];

    [Parameter]
    public EventCallback<List<SubjectEntry>> SubjectsChanged { get; set; }

    [Parameter]
    public EventCallback<SubjectEntry> OnRemove { get; set; }

    [Parameter]
    public bool RecognizedYear { get; set; }

    [Parameter]
    public EventCallback<bool> RecognizedYearChanged { get; set; }

    [Parameter]
    public bool LocalStorageLoading { get; set; }

    private int StartYear => RecognizedYear ? 0 : 1;
    private int Years => StudyContext.Years + (RecognizedYear ? 1 : 0);
    private bool NeedConfirmation => Subjects.Any(x => x.Semester == (StudyContext.Years * 2).ToString() || x.Semester == (StudyContext.Years * 2 - 1).ToString());

    private MudDropContainer<SubjectEntry>? _dropContainer;

    protected override void OnParametersSet()
    {
        if (_dropContainer is not null)
        {
            OnYearsChanged(StudyContext.Years);
        }
    }

    private Credits TotalCredits => GetTotalCredits();

    private static bool Selector(SubjectEntry item, string dropzone) => item.Semester == dropzone;

    private static bool CanDrop(SubjectEntry item, string identifier)
    {
        if (identifier == "Trash")
        {
            return item.Subject.Type != SubjectType.Compulsory || item.IsCustomSubject || item.Attempt > 1;
        }

        if (identifier == SubjectEntry.Unassigned)
        {
            return true;
        }

        if (int.TryParse(identifier, out var semester))
        {
            return item.Subject.SemesterSeason.IsValidForSemester(semester);
        }

        return true;
    }

    private async Task EntryChanged(SubjectEntry entry)
    {
        await SubjectsChanged.InvokeAsync(Subjects);
        await LocalStorageService.UpdateSubjectAsync(entry);
        _dropContainer?.Refresh();
    }

    private async Task ItemUpdated(MudItemDropInfo<SubjectEntry> dropItem)
    {
        if (dropItem.Item is null)
        {
            return;
        }

        if (dropItem.DropzoneIdentifier == "Trash")
        {
            await OnRemove.InvokeAsync(dropItem.Item);
            return;
        }

        dropItem.Item.Semester = dropItem.DropzoneIdentifier;

        Subjects.Remove(dropItem.Item);
        var itemsInZone = Subjects.Where(x => x.Semester == dropItem.DropzoneIdentifier).ToList();

        if (dropItem.IndexInZone < 0 || dropItem.IndexInZone >= itemsInZone.Count)
        {
            Subjects.Add(dropItem.Item);
        }
        else
        {
            var itemThatGotPushedDown = itemsInZone[dropItem.IndexInZone];
            var realIndex = Subjects.IndexOf(itemThatGotPushedDown);
            Subjects.Insert(realIndex, dropItem.Item);
        }

        var updatedZoneItems = Subjects
            .Where(x => x.Semester == dropItem.DropzoneIdentifier)
            .ToList();

        for (var i = 0; i < updatedZoneItems.Count; i++)
        {
            updatedZoneItems[i].IndexInZone = i;
        }

        await SubjectsChanged.InvokeAsync(Subjects);

        foreach (var item in updatedZoneItems)
        {
            await LocalStorageService.UpdateSubjectAsync(item);
        }
    }

    private Credits GetSemesterCredits(int semesterIdentifier)
    {
        var semesterSubjects = Subjects
            .Where(s => s.Semester == semesterIdentifier.ToString())
            .ToArray();

        var hasUnprocessed = semesterSubjects.Any(s => s.Completed == null);

        if (semesterIdentifier <= 0)
        {
            var registered = semesterSubjects.Sum(s => s.Subject.Credits);
            var completed = semesterSubjects.Where(s => s.Completed == true).Sum(s => s.Subject.Credits);

            return new Credits(registered, completed, false, false, hasUnprocessed);
        }

        var registeredNormal = semesterSubjects.Where(s => !s.IsSport).Sum(s => s.Subject.Credits);
        var completedNormal = semesterSubjects.Where(s => s is { Completed: true, IsSport: false }).Sum(s => s.Subject.Credits);

        var sports = semesterSubjects.Where(s => s.IsSport).ToArray();
        var totalSportsRegistered = sports.Length;
        var uniqueSportsRegistered = sports.DistinctBy(s => s.Subject.ShortName).Count();
        var uniqueSportsCompleted = sports.Where(s => s.Completed == true).DistinctBy(s => s.Subject.ShortName).Count();

        return new Credits(
            Registered: registeredNormal + Math.Min(2, uniqueSportsRegistered),
            Completed: completedNormal + Math.Min(2, uniqueSportsCompleted),
            SportLimitReached: uniqueSportsRegistered > 2,
            HasDuplicateSports: totalSportsRegistered > uniqueSportsRegistered,
            HasUnprocessed: hasUnprocessed
        );
    }

    private Credits GetYearCredits(int year)
    {
        var winterSem = year * 2 - 1;
        var summerSem = year * 2;

        return GetSemesterCredits(winterSem) + GetSemesterCredits(summerSem);
    }

    private Credits GetTotalCredits()
    {
        var assignedSubjects = Subjects.Where(x => x.Semester != SubjectEntry.Unassigned).ToArray();

        var attemptedCredits = CalculateCredits(assignedSubjects.Where(x => x.Completed != false));
        var completedCredits = CalculateCredits(assignedSubjects.Where(x => x.Completed == true));

        return new Credits(attemptedCredits, completedCredits);

        int CalculateCredits(IEnumerable<SubjectEntry> subjects)
        {
            return subjects.GroupBy(x => x.Semester).Sum(semester =>
            {
                if (semester.Key is "-1" or "0")
                {
                    return semester.Sum(x => x.Subject.Credits);
                }

                var normalCredits = semester.Where(x => !x.IsSport).Sum(x => x.Subject.Credits);
                var sportCredits = semester.Where(x => x.IsSport).DistinctBy(x => x.Subject.ShortName).Count();

                return normalCredits + Math.Min(2, sportCredits);
            });
        }
    }

    private void OnYearsChanged(int years)
    {
        StudyContext.Years = years;
        var maxValidSemester = years * 2;
        Subjects.ForEach(x =>
        {
            if (!int.TryParse(x.Semester, out var semesterNum) || semesterNum <= maxValidSemester)
            {
                return;
            }

            x.Semester = SubjectEntry.Unassigned;
            x.Completed = null;
        });

        _dropContainer?.Refresh();
    }

    private async Task OpenAddDialog()
    {
        await AnalyticsService.TrackAddButtonClickAsync();
        var result = await CreateEditCustomSubjectDialog.ShowAsync(DialogService);
        if (result.IsSuccess)
        {
            await AddSubjectAsync(result.Value);
        }
    }

    private async Task AddSubjectAsync(SubjectEntry entry)
    {
        entry.IndexInZone = Subjects.Count(x => x.Semester == entry.Semester);
        Subjects.Add(entry);
        await SubjectsChanged.InvokeAsync(Subjects);
        await LocalStorageService.UpdateSubjectAsync(entry);
        _dropContainer?.Refresh();
        Snackbar.Add(LanguageHelper.SubjectAdded, Severity.Success);
    }

    public void Refresh() => _dropContainer?.Refresh();

    private async Task RetakeSubject(SubjectEntry entry)
    {
        var latestAttempt = Subjects
            .FirstOrDefault(x => x.Subject.Id == entry.Subject.Id && x.LatestAttempt)?.Attempt ?? 0;

        if (latestAttempt > entry.Attempt)
        {
            return;
        }

        if (!int.TryParse(entry.Semester, out var result))
        {
            return;
        }

        var newSem = result + 2;
        var newEntry = new SubjectEntry(entry.Subject)
        {
            Semester = newSem.ToString(),
            IsCustomSubject = entry.IsCustomSubject,
            Completed = null,
            Attempt = latestAttempt + 1
        };
        entry.LatestAttempt = false;

        Subjects.Add(newEntry);

        if (newSem > Years * 2)
        {
            StudyContext.Years++;
            await LocalStorageService.SaveStudyYears(Years);
        }

        await LocalStorageService.UpdateSubjectAsync(entry);
        await LocalStorageService.UpdateSubjectAsync(newEntry);
        await SubjectsChanged.InvokeAsync(Subjects);
        _dropContainer?.Refresh();
        Snackbar.Add($"{LanguageHelper.RetakeSnackbarText} {newEntry.Semester}. {LanguageHelper.Semester_u}", Severity.Success);
    }

    private async Task OnCompleteSemester(int semester)
    {
        var subjectsToComplete = Subjects
            .Where(x => x.Semester == semester.ToString() && x.Completed == null)
            .ToList();

        if (subjectsToComplete.Count == 0)
        {
            return;
        }

        foreach (var subject in subjectsToComplete)
        {
            subject.Completed = true;
            await LocalStorageService.UpdateSubjectAsync(subject);
        }

        await SubjectsChanged.InvokeAsync(Subjects);
        _dropContainer?.Refresh();
        Snackbar.Add($"{LanguageHelperExtensions.Semester(semester)} {LanguageHelper.Completed}", Severity.Success);
    }
}
