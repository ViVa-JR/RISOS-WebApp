@using RISOS.Common.Models
@using RISOS.Enums
@using RISOS.Extensions
@using RISOS.Localization
@using RISOS.Pages.Home.Dialogs.AddCustomSubjectDialog
@using RISOS.Pages.Home.Models
@using RISOS.Services
@using RISOS.Helpers

@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LocalStorageService LocalStorageService
@inject AnalyticsService AnalyticsService
@inject StudyPlanService PlanService

<style>
    .card-text {
        white-space: nowrap;
        text-overflow: ellipsis;
        overflow: hidden;
    }

    .mud-icon-button:focus-within {
        background: unset !important;
    }

    .mud-overlay .app-title {
        color: var(--mud-palette-primary);
        font-size: 66px;
        letter-spacing: 2px;
        line-height: 1;
    }
</style>

<style>
    .trash-drop-zone {
        opacity: 0;
        width: 0;
        margin-left: 0;
        pointer-events: none;
        transition: opacity 0.2s ease, width 0.2s ease, margin-left 0.2s ease;
        border: 2px dashed var(--mud-palette-error) !important;
        background-color: var(--mud-palette-surface) !important;
    }

    .trash-drop-zone.mud-border-success,
    .trash-drop-zone.mud-border-error {
        opacity: 1;
        width: 120px;
        min-width: 120px;
        margin-left: 12px;
        pointer-events: auto;
    }

    .trash-drop-zone.mud-border-error {
        opacity: 0.4;
        background-color: var(--mud-palette-error-hover) !important;
        border-style: solid !important;
    }

    .trash-drop-zone .trash-disabled-icon,
    .trash-drop-zone .trash-error-text {
        display: none;
    }

    .trash-drop-zone.mud-border-error .trash-icon {
        display: none;
    }

    .trash-drop-zone.mud-border-error .trash-disabled-icon,
    .trash-drop-zone.mud-border-error .trash-error-text {
        display: block;
    }
</style>

<div style="position: relative;">
    <GlobalSearch @ref="_searchComponent" AllSubjects="@AllSubjects" OnSubjectSelected="@OnSearchSubject" />

    <MudOverlay Visible="LocalStorageLoading"
                DarkBackground="true"
                Absolute="true"
                ZIndex="9999">
        <MudStack AlignItems="AlignItems.Center">
            <MudText Class="app-title">
                RISØS
            </MudText>
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large"/>
        </MudStack>
    </MudOverlay>

    <MudDropContainer T="SubjectEntry" @ref="_dropContainer" Items="@PlanService.Subjects.ToList()" ItemsSelector="@Selector"
                      ItemDropped="@ItemUpdated"
                      CanDrop="@CanDrop"
                      Class="d-flex flex-column gap-3 mb-2"
                      Style="height: calc(100vh - 20px)"
                      ApplyDropClassesOnDragStarted
                      CanDropClass="mud-alert-text-success mud-border-success"
                      NoDropClass="mud-alert-text-error mud-border-error">
        <ChildContent>
            <MudStack Row Spacing="0" Class="w-100 hide-in-export px-0 px-md-1 pb-1" Style="z-index: 1000; position: relative;">
                <div class="rounded-lg border-2 border-dashed mud-border-lines-default mud-background-gray flex-grow-1 d-flex flex-column"
                     style="max-height: 250px; min-height: 120px;">
                    <MudStack Row Spacing="0" Class="px-4 pt-2 pb-1" AlignItems="AlignItems.Center" Style="position: relative;">
                        <MudTooltip Text="@LanguageHelper.SearchSubjectsTooltip">
                            <MudIconButton Icon="@Icons.Material.Filled.Search"
                                           Color="Color.Primary"
                                           OnClick="@(async () => { if (_searchComponent != null) { await _searchComponent.Open(); } })" />
                        </MudTooltip>
                        <MudText Typo="Typo.h6" Class="me-3" Style="margin-left: 2px">@LanguageHelper.UnassignedSubjects</MudText>
                        <MudTooltip Text="@LanguageHelper.AddCustomSubject">
                            <MudButton
                                Variant="Variant.Outlined"
                                StartIcon="@Icons.Material.Filled.AddCircleOutline"
                                IconColor="Color.Primary"
                                Color="Color.Primary"
                                OnClick="@OpenAddDialog">
                                @LanguageHelper.Add
                            </MudButton>
                        </MudTooltip>
                        <MudSpacer/>
                        <SubjectTypeLegend Class="hide-in-export"/>
                    </MudStack>
                    <div class="flex-grow-1 overflow-y-auto">
                        <MudDropZone T="SubjectEntry" Identifier="@SubjectEntry.Unassigned"
                                     Class="px-4 pb-4 pt-1 d-flex flex-wrap gap-2 border-transparent"
                                     Style="min-height: 100%;"/>
                    </div>
                </div>

                <MudDropZone T="SubjectEntry" Identifier="Trash"
                             Class="trash-drop-zone rounded-lg d-flex flex-column align-center justify-center">
                    <MudIcon Icon="@Icons.Material.Filled.DeleteForever" Size="Size.Large" Color="Color.Error" Class="trash-icon"/>
                    <MudIcon Icon="@Icons.Material.Filled.Block" Size="Size.Large" Color="Color.Error" Class="trash-disabled-icon"/>
                    <MudText Typo="Typo.caption" Color="Color.Error" Class="trash-error-text mt-1 px-2 text-center" Style="font-weight: bold; line-height: 1.2;">
                        @LanguageHelper.CompulsorySubjectDeleteError
                    </MudText>
                </MudDropZone>
            </MudStack>

            <div id="export-zone" class="d-flex flex-column gap-3 flex-grow-1" style="min-height: 0">
                <ControlCenter RecognizedYear="@RecognizedYear" RecognizedYearChanged="@RecognizedYearChanged" YearsChanged="@OnYearsChanged"
                               TotalCredits="@TotalCredits" NeedConfirmation="@NeedConfirmation"/>

                <div id="main-scroll-container" style="overflow: scroll; position: relative; flex-grow: 1;">

                    <div class="indicator-anchor top">
                        <div class="scroll-indicator top">
                            <MudIcon Icon="@Icons.Material.Filled.KeyboardDoubleArrowUp"/>
                            <MudText Typo="Typo.caption">SCROLL UP</MudText>
                        </div>
                    </div>
                    <MudStack Row Class="mb-3">
                        @foreach (var year in Enumerable.Range(StartYear, Years))
                        {
                            var winterSem = year * 2 - 1;
                            var summerSem = year * 2;

                            <div class="rounded-lg pa-4 d-flex flex-column mt-4"
                                 style="position: relative; border: 2px dotted var(--mud-palette-lines-default); height: 100%; min-width: 336px; flex: 1;">
                                <div
                                    style="position: absolute; top: -16px; left: 16px; background-color: var(--mud-palette-background); padding: 0 16px; white-space: nowrap; z-index: 10;">
                                    <MudText Typo="Typo.h6" Color="Color.Primary"
                                             Class="font-weight-bold">@(year == 0 ? LanguageHelper.RecognizedYearTitle : $"{year}. {LanguageHelper.Years_One}")</MudText>
                                </div>

                                <MudStack Class="flex-grow-1">
                                    <SemesterDropZone Semester="@winterSem" Credits="@CreditCalculator.CalculateSemesterCredits(PlanService.Subjects, winterSem)"
                                                      SemesterSeason="SemesterSeason.Winter"
                                                      CompleteSemester="@OnCompleteSemester"
                                                      SortSemester="@OnSortSemester"/>
                                    <SemesterDropZone Semester="@summerSem" Credits="@CreditCalculator.CalculateSemesterCredits(PlanService.Subjects, summerSem)"
                                                      SemesterSeason="SemesterSeason.Summer"
                                                      CompleteSemester="@OnCompleteSemester"
                                                      SortSemester="@OnSortSemester"/>
                                </MudStack>
                                <MudStack AlignItems="AlignItems.Center" Row StretchItems="StretchItems.Start" Spacing="1" Class="pt-2" Style="min-height: 40px">
                                    @{
                                        var yearSubjects = PlanService.Subjects.Where(s => s.Semester == (year * 2 - 1).ToString() || s.Semester == (year * 2).ToString()).ToList();
                                        var currentYear = DateTime.Now.Year;
                                        var yearDisplay = $"{currentYear + year - 1}/{currentYear + year}";
                                    }
                                    
                                    <GpaStatisticsMenu Subjects="@yearSubjects"
                                                       WeightedLabel="@string.Format(LanguageHelper.GpaYearlyWeighted, yearDisplay)"
                                                       CompulsoryLabel="@LanguageHelper.GpaYearlyCompulsory"
                                                       AnchorOrigin="Origin.TopLeft"
                                                       TransformOrigin="Origin.BottomLeft"
                                                       Class="mr-auto" />

                                    @if (!StudyContext.GpaPredictor || !yearSubjects.Any(s => s.Grade.HasValue && s.Grade != Grade.F && s.Subject.CompletionType.IsGraded()))
                                    {
                                        <MudText Typo="Typo.subtitle2" Color="Color.Default" Class="mr-auto">@LanguageHelper.YearTotal</MudText>
                                    }

                                    @{
                                        var yearCredits = CreditCalculator.CalculateSemesterCredits(PlanService.Subjects, year * 2 - 1) + 
                                                         CreditCalculator.CalculateSemesterCredits(PlanService.Subjects, year * 2);
                                    }

                                    @if (yearCredits.Completed > 0)
                                    {
                                        <MudText Typo="Typo.body1" Color="Color.Success">@yearCredits.Completed</MudText>
                                        <MudText Typo="Typo.body1" Color="Color.Primary">/</MudText>
                                    }
                                    <MudText Typo="Typo.body1" Color="Color.Primary">
                                        <b>@yearCredits.Registered</b> @LanguageHelper.Credits
                                    </MudText>
                                </MudStack>
                            </div>
                        }
                    </MudStack>

                    <div class="indicator-anchor bottom">
                        <div class="scroll-indicator bottom">
                            <MudText Typo="Typo.caption">SCROLL DOWN</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.KeyboardDoubleArrowDown"/>
                        </div>
                    </div>
                </div>
            </div>
        </ChildContent>
        <ItemRenderer>
            <SemesterDropZoneItemTemplate @key="@context.Key.ToString()"
                                          Entry="context"
                                          EntryChanged="@EntryChanged"
                                          SemesterCount="@(StudyContext.Years * 2)"
                                          RecognizedYear="@RecognizedYear"
                                          RemoveEntry="@OnRemove"
                                          AddEntry="@AddSubjectAsync"
                                          RetakeEntry="@RetakeSubject"/>
        </ItemRenderer>
    </MudDropContainer>
</div>

@code {
    [CascadingParameter]
    public required StudyContext StudyContext { get; set; }

    [Parameter]
    public IEnumerable<SubjectEntry> AllSubjects { get; set; } = [];

    [Parameter]
    public bool RecognizedYear { get; set; }

    [Parameter]
    public EventCallback<bool> RecognizedYearChanged { get; set; }

    [Parameter]
    public bool LocalStorageLoading { get; set; }

    private GlobalSearch? _searchComponent;

    private int StartYear => RecognizedYear ? 0 : 1;
    private int Years => StudyContext.Years + (RecognizedYear ? 1 : 0);
    private bool NeedConfirmation => PlanService.Subjects.Any(x => x.Semester == (StudyContext.Years * 2).ToString() || x.Semester == (StudyContext.Years * 2 - 1).ToString());

    private MudDropContainer<SubjectEntry>? _dropContainer;

    protected override void OnInitialized()
    {
        PlanService.OnPlanChanged += Refresh;
    }

    private Credits TotalCredits => CreditCalculator.CalculateTotalCredits(PlanService.Subjects);

    private static bool Selector(SubjectEntry item, string dropzone) => item.Semester == dropzone;

    private static bool CanDrop(SubjectEntry item, string identifier)
    {
        return identifier switch
        {
            "Trash" => item.Subject.Type != SubjectType.Compulsory || item.IsCustomSubject || item.Attempt > 1,
            SubjectEntry.Unassigned => true,
            _ => !int.TryParse(identifier, out var semester) || item.Subject.SemesterSeason.IsValidForSemester(semester)
        };
    }

    private async Task EntryChanged(SubjectEntry entry)
    {
        await PlanService.UpdateSubjectAsync(entry);
    }

    private async Task ItemUpdated(MudItemDropInfo<SubjectEntry> dropItem)
    {
        if (dropItem.Item is null)
        {
            return;
        }

        if (dropItem.DropzoneIdentifier == "Trash")
        {
            await OnRemove(dropItem.Item);
            return;
        }

        UpdateItemPosition(dropItem.Item, dropItem.DropzoneIdentifier, dropItem.IndexInZone);
        await PlanService.FixZoneIndexesAsync(dropItem.DropzoneIdentifier);
    }

    private void UpdateItemPosition(SubjectEntry item, string dropzone, int index)
    {
        item.Semester = dropzone;
        var list = PlanService.Subjects.ToList();
        list.Remove(item);

        var itemsInZone = list.Where(x => x.Semester == dropzone).ToList();

        if (index < 0 || index >= itemsInZone.Count)
        {
            list.Add(item);
        }
        else
        {
            var itemThatGotPushedDown = itemsInZone[index];
            var realIndex = list.IndexOf(itemThatGotPushedDown);
            list.Insert(realIndex, item);
        }
        PlanService.SetSubjects(list);
    }

    private async Task OnRemove(SubjectEntry entry)
    {
        await PlanService.RemoveSubjectAsync(entry);
    }

    private void OnYearsChanged(int years)
    {
        StudyContext.Years = years;
        var maxValidSemester = years * 2;
        var subjects = PlanService.Subjects.ToList();
        subjects.ForEach(x =>
        {
            if (!int.TryParse(x.Semester, out var semesterNum) || semesterNum <= maxValidSemester)
            {
                return;
            }

            x.Semester = SubjectEntry.Unassigned;
            x.Completed = null;
        });
        PlanService.SetSubjects(subjects);
    }

    private async Task OpenAddDialog()
    {
        await AnalyticsService.TrackAddButtonClickAsync();
        var result = await CreateEditCustomSubjectDialog.ShowAsync(DialogService);
        if (result.IsSuccess)
        {
            await AddSubjectAsync(result.Value);
        }
    }

    private async Task AddSubjectAsync(SubjectEntry entry)
    {
        await PlanService.AddSubjectAsync(entry);
        Snackbar.Add(LanguageHelper.SubjectAdded, Severity.Success);
    }

    public void Refresh()
    {
        _dropContainer?.Refresh();
        StateHasChanged();
    }

    private async Task OnSearchSubject(SubjectEntry? subject)
    {
        if (subject == null)
        {
            return;
        }

        await AnalyticsService.TrackGlobalSearchSubjectSelectedAsync(subject);

        switch (subject.IsSport)
        {
            case false when PlanService.Subjects.Any(x => x.Subject.Id == subject.Subject.Id):
                Snackbar.Add(LanguageHelper.SubjectAlreadyInPlan, Severity.Info);
                return;
            case true:
                await PlanService.DuplicateSportAsync(subject);
                break;
            default:
                subject.Selected = true;
                await AddSubjectAsync(subject);
                break;
        }

        _searchComponent?.Close();
    }

    private async Task RetakeSubject(SubjectEntry entry)
    {
        if (entry.IsSport)
        {
            await PlanService.DuplicateSportAsync(entry);
            return;
        }

        if (!int.TryParse(entry.Semester, out var result)) { return; }

        var newSem = result + 2;
        await PlanService.RetakeSubjectAsync(entry, newSem);

        if (newSem > Years * 2)
        {
            StudyContext.Years++;
            await LocalStorageService.SaveStudyYears(Years);
        }

        Snackbar.Add($"{LanguageHelper.RetakeSnackbarText} {newSem}. {LanguageHelper.Semester_u}", Severity.Success);
    }

    private async Task OnCompleteSemester(int semester)
    {
        var subjectsToComplete = PlanService.Subjects
            .Where(x => x.Semester == semester.ToString() && x.Completed == null)
            .ToList();

        if (subjectsToComplete.Count == 0) { return; }

        foreach (var subject in subjectsToComplete)
        {
            subject.Completed = true;
            if (StudyContext.GpaPredictor && subject.Subject.CompletionType.IsGraded())
            {
                subject.Grade = Grade.A;
            }
            await LocalStorageService.UpdateSubjectAsync(subject);
        }

        PlanService.SetSubjects(PlanService.Subjects);
        
        var message = $"{LanguageHelperExtensions.Semester(semester)} {LanguageHelper.Completed}";
        if (StudyContext.GpaPredictor && subjectsToComplete.Any(s => s.Subject.CompletionType.IsGraded()))
        {
            message += " (A)";
        }
        
        Snackbar.Add(message, Severity.Success);
    }

    private async Task OnSortSemester(int semester)
    {
        var semesterStr = semester.ToString();
        var subjectsInSemester = PlanService.Subjects.Where(x => x.Semester == semesterStr).ToList();

        if (subjectsInSemester.Count <= 1) { return; }

        var sortedSubjects = subjectsInSemester.OrderBy(x => x.Subject.Type).ThenBy(x => x.Subject.Name).ToList();
        if (subjectsInSemester.SequenceEqual(sortedSubjects)) { return; }

        for (var i = 0; i < sortedSubjects.Count; i++)
        {
            sortedSubjects[i].IndexInZone = i;
            await LocalStorageService.UpdateSubjectAsync(sortedSubjects[i]);
        }

        var allSubjects = PlanService.Subjects.ToList();
        var firstIndex = allSubjects.FindIndex(x => x.Semester == semesterStr);
        allSubjects.RemoveAll(x => x.Semester == semesterStr);
        allSubjects.InsertRange(firstIndex, sortedSubjects);

        PlanService.SetSubjects(allSubjects);
        Snackbar.Add($"{LanguageHelperExtensions.Semester(semester)} {LanguageHelper.Sorted}", Severity.Success);
    }
}
