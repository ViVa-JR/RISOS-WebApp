@using RISOS.Common.Models
@using RISOS.Enums
@using RISOS.Extensions
@using RISOS.Localization
@using RISOS.Pages.Home.Dialogs.AddCustomSubjectDialog
@using RISOS.Pages.Home.Models
@using RISOS.Services
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LocalStorageService LocalStorageService

<style>
    .card-text {
        white-space: nowrap;
        text-overflow: ellipsis;
        overflow: hidden;
    }

    .mud-icon-button:focus-within {
        background: unset !important;
    }

    .mud-overlay .app-title {
        color: var(--mud-palette-primary);
        font-size: 66px;
        letter-spacing: 2px;
        line-height: 1;
    }
</style>

<div style="position: relative;">
    <MudOverlay Visible="LocalStorageLoading"
                DarkBackground="true"
                Absolute="true"
                ZIndex="9999">
        <MudStack AlignItems="AlignItems.Center">
            <MudText Class="app-title">
                RISØS
            </MudText>
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large"/>
        </MudStack>
    </MudOverlay>

    <MudDropContainer T="SubjectEntry" @ref="_dropContainer" Items="@Subjects" ItemsSelector="@Selector"
                      ItemDropped="@ItemUpdated"
                      Class="d-flex flex-column gap-3 mb-2"
                      Style="height: calc(100vh - 20px)"
                      ApplyDropClassesOnDragStarted
                      CanDropClass="mud-alert-text-success mud-border-success"
                      NoDropClass="mud-alert-text-error mud-border-error">
        <ChildContent>
            <div class="rounded-lg border-2 border-dashed mud-border-lines-default mud-background-gray w-100 d-flex flex-column">
                <MudStack Row Spacing="3" StretchItems="StretchItems.Start" Class="px-4 pt-2 pb-2" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h6">@LanguageHelper.UnassignedSubjects</MudText>
                    <MudStack Spacing="2" Row AlignItems="AlignItems.Center" Justify="Justify.Center">
                        @foreach (var type in Enum.GetValues<SubjectType>())
                        {
                            <MudStack Row Spacing="1" Wrap="Wrap.NoWrap">
                                <MudIcon Size="Size.Small" Color="@type.ToColor()"
                                         Icon="@Icons.Material.Filled.Circle"/>
                                <MudText Typo="Typo.caption">@type.ToLabel()</MudText>
                            </MudStack>
                        }
                    </MudStack>
                    <MudTooltip Text="@LanguageHelper.AddCustomSubject">
                        <MudButton
                            Variant="Variant.Text"
                            StartIcon="@Icons.Material.Filled.AddCircleOutline"
                            IconColor="Color.Primary"
                            Color="Color.Primary"
                            OnClick="@OpenAddDialog">
                            @LanguageHelper.Add
                        </MudButton>
                    </MudTooltip>
                </MudStack>
                <MudDropZone T="SubjectEntry" Identifier="@SubjectEntry.Unassigned"
                             Class="px-4 pb-4 pt-2 d-flex flex-wrap gap-2 border-transparent rounded-b-lg overflow-y-auto"
                             Style="max-height: max(220px, 20vh); min-height: 100px;"/>
            </div>

            <ControlCenter @bind-RecognizedYear="RecognizedYear" YearsChanged="OnYearsChanged"
                           TotalCredits="TotalCredits"/>

            <div id="main-scroll-container" style="overflow: scroll; position: relative;">

                <div class="indicator-anchor top">
                    <div class="scroll-indicator top">
                        <MudIcon Icon="@Icons.Material.Filled.KeyboardDoubleArrowUp"/>
                        <MudText Typo="Typo.caption">SCROLL UP</MudText>
                    </div>
                </div>
                <MudStack Row Class="mb-3">
                    @foreach (var year in Enumerable.Range(StartYear, Years))
                    {
                        var winterSem = year * 2 - 1;
                        var summerSem = year * 2;

                        <div class="rounded-lg pa-4 d-flex flex-column mt-4"
                             style="position: relative; border: 2px dotted var(--mud-palette-lines-default); height: 100%; min-width: 336px; flex: 1;">
                            <div
                                style="position: absolute; top: -16px; left: 15%; transform: translateX(-50%); background-color: var(--mud-palette-background); padding: 0 16px;">
                                <MudText Typo="Typo.h6" Color="Color.Primary"
                                         Class="font-weight-bold">@year. @LanguageHelper.Years_One</MudText>
                            </div>

                            <MudStack Class="flex-grow-1">
                                <SemesterDropZone Semester="@winterSem" Credits="@GetSemesterCredits(winterSem)"
                                                  SemesterSeason="SemesterSeason.Winter"/>
                                <SemesterDropZone Semester="@summerSem" Credits="@GetSemesterCredits(summerSem)"
                                                  SemesterSeason="SemesterSeason.Summer"/>
                            </MudStack>
                            <MudStack AlignItems="AlignItems.Center" Row StretchItems="StretchItems.Start" Spacing="1" Class="pt-2">
                                <MudText Typo="Typo.subtitle2" Color="Color.Default">@LanguageHelper.YearTotal</MudText>

                                @{
                                    var yearCredits = GetYearCredits(year);
                                }

                                @if (yearCredits.Completed > 0)
                                {
                                    <MudText Typo="Typo.body1" Color="Color.Success">@yearCredits.Completed</MudText>
                                    <MudText Typo="Typo.body1" Color="Color.Primary">/</MudText>
                                }
                                <MudText Typo="Typo.body1" Color="Color.Primary">
                                    <b>@yearCredits.Registered</b> @LanguageHelper.Credits
                                </MudText>
                            </MudStack>
                        </div>
                    }
                </MudStack>

                <div class="indicator-anchor bottom">
                    <div class="scroll-indicator bottom">
                        <MudText Typo="Typo.caption">SCROLL DOWN</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.KeyboardDoubleArrowDown"/>
                    </div>
                </div>
            </div>
        </ChildContent>
        <ItemRenderer>
            <SemesterDropZoneItemTemplate Entry="context"
                                          EntryChanged="@EntryChanged"
                                          SemesterCount="@(Years * 2)"
                                          RemoveEntry="@OnRemove"
                                          AddEntry="@AddSubjectAsync"
                                          RetakeEntry="@RetakeSubject"/>
        </ItemRenderer>
    </MudDropContainer>
</div>

@code {
    [CascadingParameter]
    public required StudyContext StudyContext { get; set; }

    [Parameter]
    public List<SubjectEntry> Subjects { get; set; } = [];

    [Parameter]
    public EventCallback<List<SubjectEntry>> SubjectsChanged { get; set; }

    [Parameter]
    public EventCallback<SubjectEntry> OnRemove { get; set; }

    [Parameter]
    public bool RecognizedYear { get; set; }

    [Parameter]
    public bool LocalStorageLoading { get; set; }

    private int StartYear => RecognizedYear ? 0 : 1;
    private int Years => StudyContext.Years + (RecognizedYear ? 1 : 0);

    private MudDropContainer<SubjectEntry>? _dropContainer;

    protected override void OnParametersSet()
    {
        if (_dropContainer is not null)
        {
            OnYearsChanged(StudyContext.Years);
        }
    }

    private Credits TotalCredits => GetTotalCredits();

    private static bool Selector(SubjectEntry item, string dropzone) => item.Semester == dropzone;

    private async Task EntryChanged(SubjectEntry entry)
    {
        await SubjectsChanged.InvokeAsync(Subjects);
        await LocalStorageService.UpdateSubjectAsync(entry);
        _dropContainer?.Refresh();
    }

    private async Task ItemUpdated(MudItemDropInfo<SubjectEntry> dropItem)
    {
        if (dropItem.Item is null)
        {
            return;
        }

        dropItem.Item.Semester = dropItem.DropzoneIdentifier;

        Subjects.Remove(dropItem.Item);
        var itemsInZone = Subjects.Where(x => x.Semester == dropItem.DropzoneIdentifier).ToList();

        if (dropItem.IndexInZone < 0 || dropItem.IndexInZone >= itemsInZone.Count)
        {
            Subjects.Add(dropItem.Item);
        }
        else
        {
            var itemThatGotPushedDown = itemsInZone[dropItem.IndexInZone];
            var realIndex = Subjects.IndexOf(itemThatGotPushedDown);
            Subjects.Insert(realIndex, dropItem.Item);
        }

        var updatedZoneItems = Subjects
            .Where(x => x.Semester == dropItem.DropzoneIdentifier)
            .ToList();

        for (var i = 0; i < updatedZoneItems.Count; i++)
        {
            updatedZoneItems[i].IndexInZone = i;
        }

        await SubjectsChanged.InvokeAsync(Subjects);

        foreach (var item in updatedZoneItems)
        {
            await LocalStorageService.UpdateSubjectAsync(item);
        }
    }

    private Credits GetSemesterCredits(int semesterIdentifier)
    {
        var semesterSubjects = Subjects
            .Where(s => s.Semester == semesterIdentifier.ToString())
            .ToArray();

        return new Credits(
            semesterSubjects.Sum(s => s.Subject.Credits),
            semesterSubjects.Where(s => s.Completed == true).Sum(s => s.Subject.Credits)
        );
    }

    private Credits GetYearCredits(int year)
    {
        var winterSem = year * 2 - 1;
        var summerSem = year * 2;

        return GetSemesterCredits(winterSem) + GetSemesterCredits(summerSem);
    }

    private Credits GetTotalCredits()
    {
        var allSubjects = Subjects.Where(x => x.Semester != SubjectEntry.Unassigned).ToArray();

        return new Credits(
            allSubjects.Where(x => x.Completed != false).Sum(s => s.Subject.Credits),
            allSubjects.Where(s => s.Completed == true).Sum(s => s.Subject.Credits)
        );
    }

    private void OnYearsChanged(int years)
    {
        StudyContext.Years = years;
        var maxValidSemester = years * 2;
        Subjects.ForEach(x =>
        {
            if (!int.TryParse(x.Semester, out var semesterNum) || semesterNum <= maxValidSemester)
            {
                return;
            }

            x.Semester = SubjectEntry.Unassigned;
            x.Completed = null;
        });

        _dropContainer?.Refresh();
    }

    private async Task OpenAddDialog()
    {
        var result = await CreateEditCustomSubjectDialog.ShowAsync(DialogService);
        if (result.IsSuccess)
        {
            await AddSubjectAsync(result.Value);
        }
    }

    private async Task AddSubjectAsync(SubjectEntry entry)
    {
        entry.IndexInZone = Subjects.Count(x => x.Semester == entry.Semester);
        Subjects.Add(entry);
        await SubjectsChanged.InvokeAsync(Subjects);
        await LocalStorageService.UpdateSubjectAsync(entry);
        _dropContainer?.Refresh();
        Snackbar.Add(LanguageHelper.SubjectAdded, Severity.Success);
    }

    public void Refresh() => _dropContainer?.Refresh();

    private async Task RetakeSubject(SubjectEntry entry)
    {
        var latestAttempt = Subjects
            .FirstOrDefault(x => x.Subject.Id == entry.Subject.Id && x.LatestAttempt)?.Attempt ?? 0;

        if (latestAttempt > entry.Attempt)
        {
            return;
        }

        if (!int.TryParse(entry.Semester, out var result))
        {
            return;
        }

        var newSem = result + 2;
        var newEntry = new SubjectEntry(entry.Subject)
        {
            Semester = newSem.ToString(),
            IsCustomSubject = entry.IsCustomSubject,
            Completed = null,
            Attempt = latestAttempt + 1
        };
        entry.LatestAttempt = false;

        Subjects.Add(newEntry);

        if (newSem > Years * 2)
        {
            StudyContext.Years++;
            await LocalStorageService.SaveStudyYears(Years);
        }

        await LocalStorageService.UpdateSubjectAsync(entry);
        await LocalStorageService.UpdateSubjectAsync(newEntry);
        await SubjectsChanged.InvokeAsync(Subjects);
        _dropContainer?.Refresh();
        Snackbar.Add($"{LanguageHelper.RetakeSnackbarText} {newEntry.Semester}. {LanguageHelper.Semester_u}", Severity.Success);
    }
}
