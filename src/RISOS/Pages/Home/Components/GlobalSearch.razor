@using RISOS.Common.Models
@using RISOS.Enums
@using RISOS.Extensions
@using RISOS.Localization
@using RISOS.Pages.Home.Models

@inject IJSRuntime Js

@implements IAsyncDisposable

<style>
    .floating-search-overlay {
        z-index: 2000;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding-top: 20vh;
        background-color: rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(3px);
        transition: padding-top 0.3s ease;
    }

    .floating-search-overlay.searching {
        padding-top: 10vh;
    }

    .floating-search-box {
        width: 650px;
        max-width: 95vw;
        background-color: var(--mud-palette-surface);
        border-radius: 12px;
        box-shadow: var(--mud-elevation-25);
        border: 1px solid var(--mud-palette-lines-default);
        overflow: hidden;
    }

    .floating-search-box .mud-input-outlined-border {
        border: none !important;
    }

    .floating-search-box .mud-input-control {
        margin: 0;
    }

    .floating-search-box .mud-input-adornment-start {
        color: var(--mud-palette-primary);
        margin-left: 12px;
    }

    .floating-search-box .mud-input-slot {
        font-size: 1.25rem;
        padding: 16px 20px !important;
    }

    .search-item-disabled {
        opacity: 0.5;
        filter: grayscale(1);
    }

    .short-name-badge {
        padding: 0 12px;
        border-radius: 4px;
        min-width: 52px;
        height: 48px;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 0.85rem;
    }
</style>

<MudOverlay Visible="@_visible" OnClick="@Close" Class="@($"floating-search-overlay {(string.IsNullOrEmpty(_searchString) ? "" : "searching")}")" AutoClose="false" LockScroll="true">
    <div class="floating-search-box" @onclick:stopPropagation>
        <MudAutocomplete T="SubjectEntry"
                         @ref="_autocomplete"
                         SearchFunc="@SearchSubjects"
                         Placeholder="@LanguageHelper.SearchAllSubjects"
                         ToStringFunc="@((SubjectEntry x) => x?.Subject.Name)"
                         ValueChanged="@OnSubjectSelected"
                         @bind-Text="@_searchString"
                         Dense
                         Margin="Margin.None"
                         Variant="Variant.Outlined"
                         Adornment="Adornment.Start"
                         AdornmentIcon="@Icons.Material.Filled.Search"
                         AdornmentColor="Color.Primary"
                         Clearable
                         SelectValueOnTab
                         OpenIcon="none"
                         CloseIcon="none"
                         MaxItems="10">
            <ItemTemplate Context="subjectContext">
                @{
                    var isAdded = SelectedSubjects.Any(s => s.Subject.Id == subjectContext.Subject.Id && !subjectContext.IsSport);
                }
                <div class="d-flex align-center gap-4 w-100 py-2 px-1 @(isAdded ? "search-item-disabled" : "")" style="min-width: 400px;">
                    <div class="short-name-badge mud-theme-@subjectContext.Subject.Type.ToColor().ToString().ToLower() white-text font-weight-bold">
                        @subjectContext.Subject.ShortName
                    </div>
                    <div class="d-flex flex-column overflow-hidden flex-grow-1">
                        <MudText Typo="Typo.body1" Class="text-truncate font-weight-bold">@subjectContext.Subject.Name</MudText>
                        <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @subjectContext.Subject.Credits @LanguageHelper.Cr •
                            </MudText>
                            <MudText Typo="Typo.body2" Color="@subjectContext.Subject.SemesterSeason.ToColor()" Style="font-weight: 500;">
                                @subjectContext.Subject.SemesterSeason.ToLabel()
                            </MudText>
                            <MudChip T="SubjectType"
                                     Text="@subjectContext.Subject.Type.ToLabel()"
                                     Size="Size.Small"
                                     Variant="Variant.Text"
                                     Color="@subjectContext.Subject.Type.ToColor()"
                                     Class="ma-0" />
                        </MudStack>
                    </div>
                    @if (isAdded)
                    {
                        <MudChip T="string"
                                 Text="@LanguageHelper.AlreadyRegistered"
                                 Size="Size.Small"
                                 Color="Color.Success"
                                 Variant="Variant.Outlined"
                                 Class="ml-2" />
                    }
                </div>
            </ItemTemplate>
        </MudAutocomplete>
    </div>
</MudOverlay>

@code {
    [Parameter]
    public IEnumerable<SubjectEntry> AllSubjects { get; set; } = [];

    [Parameter]
    public IEnumerable<SubjectEntry> SelectedSubjects { get; set; } = [];

    [Parameter]
    public EventCallback<SubjectEntry> OnSubjectSelected { get; set; }

    private bool _visible;
    private string _searchString = string.Empty;
    private MudAutocomplete<SubjectEntry>? _autocomplete;
    private DotNetObjectReference<GlobalSearch>? _objRef;

    public async Task Open()
    {
        _visible = true;
        _searchString = string.Empty;
        StateHasChanged();
        await Task.Delay(100);
        if (_autocomplete != null)
        {
            await _autocomplete.FocusAsync();
        }
    }

    public void Close()
    {
        _visible = false;
        _searchString = string.Empty;
        StateHasChanged();
    }

    private Task<IEnumerable<SubjectEntry>> SearchSubjects(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value))
        {
            return Task.FromResult<IEnumerable<SubjectEntry>>([]);
        }

        var compareInfo = System.Globalization.CultureInfo.InvariantCulture.CompareInfo;
        const System.Globalization.CompareOptions compareOptions = System.Globalization.CompareOptions.IgnoreCase | System.Globalization.CompareOptions.IgnoreNonSpace;

        var result = AllSubjects.Where(x =>
            (!string.IsNullOrWhiteSpace(x.Subject.Name) && compareInfo.IndexOf(x.Subject.Name, value, compareOptions) >= 0) ||
            (!string.IsNullOrWhiteSpace(x.Subject.ShortName) && compareInfo.IndexOf(x.Subject.ShortName, value, compareOptions) >= 0) ||
            (!string.IsNullOrWhiteSpace(x.Subject.GroupId) && compareInfo.IndexOf(x.Subject.GroupId, value, compareOptions) >= 0)
        );

        return Task.FromResult(result);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            await Js.InvokeVoidAsync("searchShortcut.init", _objRef);
        }
    }

    [JSInvokable]
    public async Task OpenSearchFromJs() => await Open();

    [JSInvokable]
    public void CloseSearchFromJs() => Close();

    public async ValueTask DisposeAsync()
    {
        try
        {
            await Js.InvokeVoidAsync("searchShortcut.dispose");
        }
        catch (Exception) { }
        _objRef?.Dispose();
    }
}
