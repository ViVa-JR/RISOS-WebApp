@typeparam TGroupKey

@using RISOS.Localization
@using RISOS.Pages.Home.Models

<style>
    .count-chip {
        color: white;
        border-color: white;
    }
    
    .error-chip {
        color: var(--mud-palette-error);
        border-color: var(--mud-palette-error);
    }
</style>

<MudExpansionPanel Disabled="@Disabled" @bind-Expanded="_expanded" HideIcon="true">
    <TitleContent>
        <MudStack StretchItems="StretchItems.Start" Row Spacing="2" AlignItems="AlignItems.Center">
            <MudText Class="mud-expand-panel-text" Style="font-size: 15px">
                @Title
            </MudText>
            @if (Count > 0)
            {
                <MudTooltip Text="@(EveryGroupSelected ? string.Empty : LanguageHelper.CompulsoryElectiveErrorMessage)">
                    <MudChip T="int" Variant="Variant.Outlined" Size="Size.Small" Style="margin: 0 !important;" Class="@(EveryGroupSelected ? "count-chip" : "error-chip")">
                        @Count
                    </MudChip>
                </MudTooltip>
            }
            @if (IsLoading)
            {
                <MudProgressCircular Indeterminate Size="Size.Small" Color="Color.Secondary"/>
            }
            else
            {
                <MudIcon Icon="@(_expanded ? Icons.Material.Filled.KeyboardArrowUp : Icons.Material.Filled.KeyboardArrowDown)"/>
            }
        </MudStack>
    </TitleContent>
    <ChildContent>
        <SubjectsList TGroupKey="TGroupKey"
                      Groups="Groups"
                      HeaderTemplate="HeaderTemplate"
                      ReadOnly="@ReadOnly"
                      FixedPixels="FixedPixels"
                      SubjectChanged="@SubjectChanged" />
    </ChildContent>
</MudExpansionPanel>

@code {
    [Parameter, EditorRequired]
    public required Func<SubjectEntry, TGroupKey> GroupBy { get; set; }

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public Dictionary<SubjectEntryKey, SubjectEntry> Subjects { get; set; } = [];

    [Parameter]
    public EventCallback<SubjectEntry> SubjectChanged { get; set; }

    [Parameter]
    public bool ReadOnly { get; set; }

    [Parameter]
    public int FixedPixels { get; set; }

    [Parameter]
    public Func<TGroupKey, string>? HeaderTemplate { get; set; }

    [Parameter]
    public bool CompulsoryGroups { get; set; }

    private bool _expanded;

    private int Count => Subjects.Count;

    private IEnumerable<IGrouping<TGroupKey, SubjectEntry>> Groups => Subjects.Values.GroupBy(GroupBy);
    private bool EveryGroupSelected => !CompulsoryGroups || (Groups.Any() && Groups.All(group => group.Any(entry => entry.Selected)));

}
