@using RISOS.Services

@inject ThemeStateService ThemeStateService

<style>
    .app-title {
        transition: transform 225ms ease-in-out;
        font-size: 32px;
        font-weight: 500;
        letter-spacing: 3px;
        font-family: 'Poppins', sans-serif;
        margin: 0;
        order: 2;
    }

    .drawer-closed .app-title {
        order: 3;
        transform: rotate(-90deg);
        margin-top: 35px !important;
    }

    .theme-button {
        order: 1;
    }

    .drawer-closed .theme-button {
        order: 2;
    }

    .drawer-toggle-button {
        order: 3;
    }

    .drawer-closed .drawer-toggle-button {
        order: 1;
    }
</style>

<MudDrawer @bind-Open="_drawerOpen" Elevation="1" Breakpoint="Breakpoint.Sm" Variant="@DrawerVariant.Mini" Color="Color.Primary" Class="@($"mt-n5 {Class}")">
    <MudStack Row="@_drawerOpen"
              AlignItems="AlignItems.Center"
              Justify="@(_drawerOpen ? Justify.SpaceBetween : Justify.FlexStart)"
              Spacing="1"
              Class="@($"pa-1 {(_drawerOpen ? string.Empty : "drawer-closed")}")"
              Style="flex-shrink: 0;">

        <MudToggleIconButton Class="theme-button"
                             Toggled="ThemeStateService.IsDarkMode"
                             ToggledChanged="ThemeStateService.SetDarkMode"
                             Icon="@Icons.Material.Filled.NightsStay"
                             Color="@Color.Dark"
                             ToggledIcon="@Icons.Material.Filled.WbSunny"
                             ToggledColor="@Color.Secondary"/>

        <MudText Class="app-title" Color="Color.Surface">
            RISØS
        </MudText>

        <MudIconButton Class="drawer-toggle-button"
                       OnClick="@DrawerToggle"
                       Icon="@(_drawerOpen ? Icons.Material.Filled.KeyboardArrowLeft : Icons.Material.Filled.KeyboardArrowRight)"
                       Color="@Color.Default"/>

    </MudStack>

    @if (_drawerOpen && ChildContent is not null)
    {
        <MudStack Class="pa-2" Style="overflow-y: auto; flex: 1; overflow-x: hidden;">
            @ChildContent
        </MudStack>
    }
</MudDrawer>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string Class { get; set; } = string.Empty;

    private bool _drawerOpen = true;

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;
}