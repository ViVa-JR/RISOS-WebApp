@using RISOS.Services
@inject ThemeStateService ThemeStateService
@inject IJSRuntime Js

<script>
    window.setupHeightObserver = function (elementId, cssVariableName) {
        if (window.__myHeightObserver) {
            window.__myHeightObserver.disconnect();
        }

        const targetElement = document.getElementById(elementId);

        if (!targetElement) {
            return;
        }

        window.__myHeightObserver = new ResizeObserver(entries => {
            if (debounceTimer) clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => {
                for (let entry of entries) {
                    if (targetElement.offsetParent !== null) {
                        const newHeight = entry.contentRect.height;
                        document.documentElement.style.setProperty(cssVariableName, `${newHeight}px`);
                    }
                }
            }, 50);
        });

        let debounceTimer = null;
        window.__myHeightObserver.observe(targetElement);

        const initialHeight = targetElement.getBoundingClientRect().height;
        document.documentElement.style.setProperty(cssVariableName, `${initialHeight}px`);
    };
</script>
<style>
    .sidebar-header {
        display: flex;
        align-items: center;
        transition: padding 300ms ease;
        position: relative;
    }

    .sidebar-header.drawer-open {
        flex-direction: row;
        height: 56px;
        padding: 0 4px;
        justify-content: space-between;
    }

    .sidebar-header.drawer-closed {
        flex-direction: column;
        padding: 8px 0;
        width: 100%;
        justify-content: flex-start;
    }

    .sidebar-header.drawer-closed .drawer-toggle-button,
    .sidebar-header.drawer-closed .theme-button {
        width: 100%;
        display: flex;
        justify-content: center;
    }

    .sidebar-header.drawer-open .theme-button {
        order: 1;
    }

    .sidebar-header.drawer-open .drawer-toggle-button {
        order: 3;
    }

    .app-title {
        transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1),
        top 300ms cubic-bezier(0.4, 0, 0.2, 1),
        left 300ms cubic-bezier(0.4, 0, 0.2, 1),
        opacity 250ms ease;
        font-size: 44px;
        font-family: 'Aladin', cursive;
        letter-spacing: 2px;
        line-height: 1;
        white-space: nowrap;
        display: inline-block;
        transform-origin: center center;
        margin: 0;
        position: absolute;
        pointer-events: none;
    }

    .drawer-open .app-title {
        left: 50%;
        top: 50%;
        transform: translate(-50%, -30%) scale(1);
    }

    .drawer-closed .app-title {
        left: 56%;
        top: 170px;
        transform: translate(-50%, -50%) rotate(-90deg) scale(0.85);
    }

    .drawer-content-wrapper {
        transition: opacity 200ms ease;
        opacity: 1;
        visibility: visible;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        overflow: hidden;
    }

    .drawer-closed-content {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        flex-grow: 0;
        height: 0;
    }

    .drawer-closed-bottom-wrapper .mud-stack-row {
        flex-direction: column !important;
        gap: 0 !important;
        align-items: center !important;
        width: 100% !important;
    }
</style>

<style>
    .mobile-hidden-sidebar {
        display: none !important;
    }

    @@media (min-width: 960px) {
        .mobile-hidden-sidebar {
            display: flex !important;
        }
    }
</style>

<MudDrawer @bind-Open="_drawerOpen" Elevation="1" Breakpoint="Breakpoint.None" Variant="@(IsReadOnly ? DrawerVariant.Temporary : DrawerVariant.Mini)"
           Class="@($"mt-n5 mobile-hidden-sidebar {Class}")" Width="260px" Overlay="false">

    <div class="@($"sidebar-header {(_drawerOpen ? "drawer-open" : "drawer-closed")}")">
        <MudIconButton
            OnClick="@DrawerToggle"
            Icon="@(_drawerOpen ? Icons.Material.Filled.KeyboardArrowLeft : Icons.Material.Filled.KeyboardArrowRight)"
            Style="color: var(--mud-palette-drawer-text)"
            Class="drawer-toggle-button"/>

        <MudToggleIconButton
            Toggled="ThemeStateService.IsDarkMode"
            ToggledChanged="ThemeStateService.SetDarkMode"
            Icon="@Icons.Material.Filled.NightsStay"
            ToggledIcon="@Icons.Material.Filled.WbSunny"
            Style="color: var(--mud-palette-drawer-text)"
            Class="theme-button"/>

        <MudText Class="app-title">
            RISØS
        </MudText>
    </div>

    <div class="@($"drawer-content-wrapper {(_drawerOpen ? "" : "drawer-closed-content")}")">
        <div id="side-bar-content" class="pa-2 d-flex flex-column"
             style="overflow-y: auto; overflow-x: hidden; height: 100%;">
            @OpenedDrawerContent
        </div>
    </div>

    @if (AlwaysVisible is not null)
    {
        <MudSpacer/>
        <div class="@($"pa-2 {(_drawerOpen ? "w-100" : "drawer-closed-bottom-wrapper d-flex flex-column align-center")}")">
            @AlwaysVisible
        </div>
    }
</MudDrawer>

@code {
    [CascadingParameter]
    public bool IsReadOnly { get; set; }

    [Parameter]
    public RenderFragment? OpenedDrawerContent { get; set; }

    [Parameter]
    public RenderFragment? AlwaysVisible { get; set; }

    [Parameter]
    public string Class { get; set; } = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Js.InvokeVoidAsync("setupHeightObserver", "side-bar-content", "--side-bar-content-height");
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private bool _drawerOpen = true;

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;
}
