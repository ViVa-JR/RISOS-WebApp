@using RISOS.Models
@using RISOS.Pages.Home.Models
<MudPaper Elevation="0" Class="pa-3 border-2 mud-border-lines-default rounded-lg">
    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">

        <MudButton Variant="@(RecognizedYear ? Variant.Filled : Variant.Outlined)"
                   Color="@Color.Primary"
                   OnClick="@OnRecognizedYearClick"
                   StartIcon="@(RecognizedYear ? Icons.Material.Filled.BookmarkRemove : Icons.Material.Filled.BookmarkAdd)"
                   Size="Size.Small">
            @(RecognizedYear ? "Remove recognized year" : "Add recognized year")
        </MudButton>

        <MudStack Spacing="1" Class="flex-grow-1 px-8" AlignItems="AlignItems.Center">

            <MudStack Row Spacing="2" AlignItems="AlignItems.Baseline">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Study Progress:
                </MudText>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                    @if (TotalCredits.Completed > 0)
                    {
                        <MudTooltip Text="Completed">
                            <MudText Typo="Typo.h6" Color="Color.Success">@TotalCredits.Completed</MudText>
                        </MudTooltip>
                        <MudText>/</MudText>
                    }

                    @if (TotalCredits.Registered > 0)
                    {
                        <MudTooltip Text="Registered">
                            <MudText Typo="Typo.h6" Color="Color.Primary">@TotalCredits.Registered</MudText>
                        </MudTooltip>
                        <MudText>/</MudText>
                    }

                    <MudTooltip Text="Required">
                        <MudText Typo="Typo.h6" Color="Color.Default">@StudyContext.RequiredCredits cr</MudText>
                    </MudTooltip>
                </MudStack>
            </MudStack>

            <div class="w-100 rounded-pill d-flex" style="height: 6px; background-color: var(--mud-palette-lines-default); overflow: hidden;">
                <div style="width: @(CompletedProgress)%; background-color: var(--mud-palette-success); transition: width 0.3s ease;"></div>
                <div style="width: @(RegisteredProgress)%; background-color: var(--mud-palette-info); transition: width 0.3s ease;"></div>
            </div>

        </MudStack>

        <MudStack Row AlignItems="AlignItems.Center" Spacing="3">

            <div class="text-center">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; margin-bottom: -4px;">Duration</MudText>
                <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@Years Years</MudText>
            </div>

            <MudTooltip Text="Adjust amount of years">
                <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                    <MudIconButton Icon="@Icons.Material.Filled.Remove" Color="Color.Error" OnClick="@DecreaseYears" Disabled="@(Years <= 1)"/>
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Success" OnClick="@IncreaseYears"/>
                </MudButtonGroup>
            </MudTooltip>

        </MudStack>

    </MudStack>
</MudPaper>

@code {

    [Parameter, EditorRequired]
    public required Credits TotalCredits { get; set; }

    [Parameter]
    public bool RecognizedYear { get; set; }

    [Parameter]
    public EventCallback<bool> RecognizedYearChanged { get; set; }

    [Parameter]
    public int Years { get; set; }

    [Parameter]
    public EventCallback<int> YearsChanged { get; set; }

    [Parameter]
    public required StudyContext StudyContext { get; set; }

    private int SafeNeededCredits => StudyContext.RequiredCredits > 0 ? StudyContext.RequiredCredits : 180;

    private int CompletedProgress => TotalCredits.Completed > 0
        ? (int)Math.Min(100, Math.Round((double)TotalCredits.Completed / SafeNeededCredits * 100))
        : 0;

    private int RegisteredProgress
    {
        get
        {
            if (TotalCredits.Registered <= TotalCredits.Completed) return 0;

            var pendingCredits = TotalCredits.Registered - TotalCredits.Completed;
            var pct = (int)Math.Round((double)pendingCredits / SafeNeededCredits * 100);

            return Math.Min(pct, 100 - CompletedProgress);
        }
    }

    private async Task OnRecognizedYearClick()
    {
        RecognizedYear = !RecognizedYear;
        await RecognizedYearChanged.InvokeAsync(RecognizedYear);
    }

    private async Task DecreaseYears()
    {
        Years = Math.Max(0, Years - 1);
        await YearsChanged.InvokeAsync(Years);
    }

    private async Task IncreaseYears()
    {
        await YearsChanged.InvokeAsync(++Years);
    }

}
