@using RISOS.Common.Models
@using RISOS.Enums
@using RISOS.Extensions
@using RISOS.Localization
@using RISOS.Pages.Home.Dialogs
@using RISOS.Pages.Home.Dialogs.CreditsDialog
@using RISOS.Pages.Home.Dialogs.SettingsDialog
@using RISOS.Pages.Home.Dialogs.ShareDialog
@using RISOS.Pages.Home.Models
@using RISOS.Services

@inject LocalStorageService LocalStorageService
@inject IDialogService DialogService
@inject ThemeStateService ThemeStateService
@inject LanguageService LanguageService
@inject NavigationManager NavigationManager
@inject AnalyticsService AnalyticsService
@inject StudyPlanService PlanService

<style>
    .mud-icon-button:focus-within {
        background-color: transparent !important;
    }

    .mud-icon-button.mud-button-filled:focus-within {
        background-color: var(--mud-palette-primary) !important;
    }

    .mud-icon-button.mud-button-filled.mud-button-filled-primary:hover {
        background-color: var(--mud-palette-primary-hover) !important;
    }
</style>

<MudPaper Elevation="0" Class="py-2 px-3 border-2 mud-border-lines-default rounded-lg">
    <div class="d-flex flex-column flex-md-row align-center justify-space-between gap-0 gap-md-4">
        @if (!IsReadOnly)
        {
            <div class="d-flex w-100 w-md-auto justify-center justify-md-start order-1 mt-0 mt-md-0">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h5" Color="Color.Primary" Class="font-weight-bold" Style="line-height: 1.1">
                        @StudyContext.FacultyAbbreviation
                    </MudText>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.subtitle1" Class="mud-text-secondary font-weight-bold">
                            @StudyContext.ProgramAbbreviation
                        </MudText>
                        @if (!string.IsNullOrWhiteSpace(StudyContext.ProgramSpecialization))
                        {
                            <MudDivider Vertical="true" FlexItem="true" Style="height: 16px; margin: auto 0; border-width: 2px;"/>
                            <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">
                                @StudyContext.ProgramSpecialization
                            </MudText>
                        }

                        <GpaStatisticsMenu Subjects="@PlanService.Subjects"
                                           WeightedLabel="@LanguageHelper.GpaTotalWeighted"
                                           CompulsoryLabel="@LanguageHelper.GpaTotalCompulsory"
                                           Class="d-none d-md-inline-flex"/>
                    </MudStack>
                </MudStack>
            </div>
        }

        <div class="d-flex flex-column flex-grow-1 w-100 px-0 px-md-4 order-2 mt-2 mt-md-0">
            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2" Class="mb-1">
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="@(IsReadOnly ? "d-none" : "")">
                    @LanguageHelper.StudyProgress:
                </MudText>

                <MudStack Row Spacing="1" AlignItems="AlignItems.Center">
                    @if (TotalCredits.Completed > 0)
                    {
                        <MudTooltip Text="@LanguageHelper.Completed">
                            <MudText Typo="Typo.h6" Color="Color.Success" Class="font-weight-bold">@TotalCredits.Completed</MudText>
                        </MudTooltip>
                        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="font-weight-bold">/</MudText>
                    }

                    @if (TotalCredits.Registered > 0)
                    {
                        <MudTooltip Text="@LanguageHelper.Registered">
                            <MudText Typo="Typo.h6" Color="Color.Primary" Class="font-weight-bold">@TotalCredits.Registered</MudText>
                        </MudTooltip>
                        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="font-weight-bold">/</MudText>
                    }

                    <MudTooltip Text="@LanguageHelper.Required">
                        <MudText Typo="Typo.h6" Color="Color.Default" Class="font-weight-bold" Style="white-space: nowrap">
                            @StudyContext.Credits @LanguageHelper.Cr
                        </MudText>
                    </MudTooltip>

                    @if (!IsReadOnly && StudyContext is { CreditsWarn: true, CreditOverride: null })
                    {
                        <MudTooltip Text="@LanguageHelper.CreditsWarning" RootClass="hide-in-export">
                            <MudIconButton Icon="@Icons.Material.Filled.WarningAmber" Color="Color.Warning" Size="Size.Small" OnClick="@OnCreditWarningClick" Class="pa-0 ml-1"/>
                        </MudTooltip>
                    }
                </MudStack>
            </MudStack>

            <div class="w-100 rounded-pill d-flex"
                 style="height: 6px; background-color: var(--mud-palette-lines-default); overflow: hidden;">
                <div
                    style="width: @(CompletedProgress)%; background-color: var(--mud-palette-success); transition: width 0.3s ease;"></div>
                <div
                    style="width: @(RegisteredProgress)%; background-color: var(--mud-palette-info); transition: width 0.3s ease;"></div>
            </div>
        </div>

        <div class="d-flex align-center justify-space-between justify-md-end gap-3 w-100 w-md-auto order-3 mb-2 mb-md-0 mt-1">
            <GpaStatisticsMenu Subjects="@PlanService.Subjects"
                               WeightedLabel="@LanguageHelper.GpaTotalWeighted"
                               CompulsoryLabel="@LanguageHelper.GpaTotalCompulsory"
                               AnchorOrigin="Origin.BottomLeft"
                               TransformOrigin="Origin.TopLeft"
                               Class="hide-in-export d-inline-flex d-md-none"/>

            @if (IsReadOnly)
            {
                <div class="d-flex align-center hide-in-export">
                    <MudToggleIconButton Toggled="ThemeStateService.IsDarkMode"
                                         ToggledChanged="ThemeStateService.SetDarkMode"
                                         Icon="@Icons.Material.Filled.NightsStay"
                                         ToggledIcon="@Icons.Material.Filled.WbSunny"/>
                    <MudIconButton Icon="@Icons.Material.Filled.Share" OnClick="@OnShareClick"/>
                    <MudIconButton Icon="@Icons.Material.Filled.Settings" OnClick="@OnSettingsClick"/>
                </div>
            }

            <div class="d-flex align-center gap-3">
                @if (!IsReadOnly)
                {
                    <div class="hide-in-export">
                        <MudTooltip Text="@(RecognizedYear ? LanguageHelper.RemoveRecognizedYear : LanguageHelper.AddRecognizedYear)">
                            <MudToggleIconButton Toggled="@RecognizedYear"
                                                 ToggledChanged="@OnRecognizedYearClick"
                                                 Icon="@Icons.Material.Filled.BookmarkAdd"
                                                 ToggledIcon="@Icons.Material.Filled.BookmarkRemove"
                                                 Color="@Color.Primary"
                                                 ToggledColor="@Color.Primary"
                                                 Variant="@Variant.Outlined"
                                                 ToggledVariant="@Variant.Filled"
                                                 Size="Size.Small"/>
                        </MudTooltip>
                    </div>
                }

                <div class="hide-in-export d-flex align-center gap-3">
                    <div class="text-right">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; margin-bottom: -4px;">@LanguageHelper.Duration</MudText>
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold" Style="text-align: center">@StudyContext.Years @LanguageHelperExtensions.Years(StudyContext.Years)</MudText>
                    </div>

                    @if (!IsReadOnly)
                    {
                        <MudTooltip Text="@LanguageHelper.AdjustYears">
                            <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                                <MudIconButton Icon="@Icons.Material.Filled.Remove" Color="Color.Error" OnClick="@DecreaseYears" Disabled="@(StudyContext.Years <= 1)"/>
                                <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Success" OnClick="@IncreaseYears"/>
                            </MudButtonGroup>
                        </MudTooltip>
                    }
                </div>
                <div class="show-only-in-export">
                    <div class="d-flex align-center gap-4">
                        <SubjectTypeLegend/>
                        <MudText Typo="Typo.h5" Class="font-weight-bold mud-primary-text" Style="opacity: 0.15; letter-spacing: 4px; user-select: none;">
                            RISØS
                        </MudText>
                    </div>
                </div>
            </div>
        </div>
    </div>
</MudPaper>

@code {
    [CascadingParameter]
    public bool IsReadOnly { get; set; }

    [CascadingParameter]
    public required StudyContext StudyContext { get; set; }

    [Parameter]
    [EditorRequired]
    public required Credits TotalCredits { get; set; }

    [Parameter]
    public bool RecognizedYear { get; set; }

    [Parameter]
    public EventCallback<bool> RecognizedYearChanged { get; set; }

    [Parameter]
    public EventCallback<int> YearsChanged { get; set; }

    [Parameter]
    public bool NeedConfirmation { get; set; }

    private int SafeNeededCredits => StudyContext.Credits > 0 ? StudyContext.Credits : 180;

    private int CompletedProgress => TotalCredits.Completed > 0
        ? (int)Math.Min(100, Math.Round((double)TotalCredits.Completed / SafeNeededCredits * 100))
        : 0;

    private int RegisteredProgress
    {
        get
        {
            if (TotalCredits.Registered <= TotalCredits.Completed)
            {
                return 0;
            }

            var pendingCredits = TotalCredits.Registered - TotalCredits.Completed;
            var pct = (int)Math.Round((double)pendingCredits / SafeNeededCredits * 100);

            return Math.Min(pct, 100 - CompletedProgress);
        }
    }

    private async Task OnRecognizedYearClick(bool toggled)
    {
        RecognizedYear = toggled;
        await AnalyticsService.TrackRecognizedYearToggleAsync(RecognizedYear);
        await LocalStorageService.SaveRecognizedYear(RecognizedYear);
        await RecognizedYearChanged.InvokeAsync(RecognizedYear);
    }

    private async Task DecreaseYears()
    {
        if (NeedConfirmation)
        {
            var result = await ConfirmationDialog.ShowAsync(DialogService);
            if (result.IsCancelled || result.IsFailure)
            {
                return;
            }
        }

        var previousYears = StudyContext.Years;
        var newYears = Math.Max(0, StudyContext.Years - 1);
        StudyContext.Years = newYears;
        await AnalyticsService.TrackStudyYearsChangedAsync("decrease", previousYears, newYears);
        await YearsChanged.InvokeAsync(newYears);
        await LocalStorageService.SaveStudyYears(StudyContext.Years);
    }

    private async Task IncreaseYears()
    {
        var previousYears = StudyContext.Years;
        var newYears = StudyContext.Years + 1;
        StudyContext.Years = newYears;
        await AnalyticsService.TrackStudyYearsChangedAsync("increase", previousYears, newYears);
        await YearsChanged.InvokeAsync(newYears);
        await LocalStorageService.SaveStudyYears(StudyContext.Years);
    }

    private async Task OnCreditWarningClick()
    {
        var result = await CreditsDialog.ShowAsync(DialogService, StudyContext.Credits);
        if (result.IsCancelled || result.IsFailure)
        {
            return;
        }

        StudyContext.CreditOverride = result.Value.Credits;
        await LocalStorageService.SaveCreditOverride(result.Value.Credits);
    }

    private async Task OnSettingsClick()
    {
        var previousTheme = ThemeStateService.CurrentThemeType ?? ThemeType.Default;
        var previousLanguage = await LanguageService.GetAppLanguageAsync();

        var result = await SettingsDialog.ShowAsync(DialogService, StudyContext, IsReadOnly);
        if (result.IsCancelled || result.IsFailure)
        {
            return;
        }

        await ThemeStateService.SetThemeType(result.Value.SelectedTheme);
        if (result.Value.SelectedTheme != previousTheme)
        {
            await AnalyticsService.TrackThemeChangedAsync(previousTheme, result.Value.SelectedTheme);
        }

        if (result.Value.Language != previousLanguage)
        {
            await AnalyticsService.TrackLanguageChangedAsync(previousLanguage, result.Value.Language);
            await LanguageService.SetAppLanguageAsync(result.Value.Language);
            NavigationManager.NavigateTo(NavigationManager.Uri, true);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnShareClick() => await ShareDialog.ShowAsync(DialogService);
}
