@using MudExtensions
@using RISOS.Localization
@using RISOS.Pages.Home.Models

<style>
    .study-program-selector-list .mud-list-item-extended:hover {
        opacity: 0.9;
    }

    .study-program-selector-list .mud-selected-item {

        .mud-chip {
            color: var(--mud-palette-primary) !important;
            border-color: var(--mud-palette-primary) !important;
        }
        
        .label {
            color: var(--mud-palette-primary) !important;
        }
    }

    .label {
        color: var(--mud-palette-text-primary);
    }
</style>

<MudListItemExtended T="StudyProgram" Value="@Program" Style="background-color: var(--mud-palette-surface) !important;">
    <MudTooltip Text="@Program.Title" RootStyle="width: 100%;" RootClass="d-flex pt-2 pb-2">
        @if (Program.Specialization != null)
        {
            <MudStack Row Spacing="2" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ma-0">
                    @Program.Abbreviation
                </MudChip>

                <MudText Typo="Typo.body2" Class="text-nowrap label">
                    <b>@Program.Specialization</b>
                </MudText>
            </MudStack>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="label">
                <b>@Program.Abbreviation</b>
            </MudText>
        }
        <MudSpacer/>
        <MudLink Href="@Program.Url" Target="_blank">
            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Outlined.Info" Color="Color.Info" Class="flex-shrink-0" title="@LanguageHelper.ShowProgramInfo"/>
        </MudLink>
    </MudTooltip>
</MudListItemExtended>

@code {
    [Parameter, EditorRequired] public required StudyProgram Program { get; set; }
}
