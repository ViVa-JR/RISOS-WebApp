@using MudExtensions
@using RISOS.Pages.Home.Models

<style>
    .mud-list-item-extended:hover {
        opacity: 0.9;
    }
</style>

<MudListItemExtended T="StudyProgram" Value="@Program" Style="background-color: var(--mud-palette-surface) !important;">
    <MudTooltip Text="@Program.Title" RootStyle="width: 100%;" RootClass="d-flex pt-2 pb-2">
        @if (Program.Specialization != null)
        {
            <MudStack Row Spacing="2" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" Class="ma-0">
                    @Program.Abbreviation
                </MudChip>
    
                <MudText Typo="Typo.body2" Color="Color.Primary" Class="text-nowrap">
                    <b>@Program.Specialization</b>
                </MudText>
            </MudStack>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Primary">
                <b>@Program.Abbreviation</b>
            </MudText>
        }
    </MudTooltip>
</MudListItemExtended>

@code {
    [Parameter,EditorRequired] public required StudyProgram Program { get; set; }
}