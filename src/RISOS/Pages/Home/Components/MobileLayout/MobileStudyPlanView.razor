@using RISOS.Common.Models
@using RISOS.Enums
@using RISOS.Extensions
@using RISOS.Localization
@using RISOS.Pages.Home.Models
@using RISOS.Services
@using RISOS.Helpers

<style>
    .mobile-snap-container {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        overscroll-behavior-x: none;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        width: 100%;
        gap: 16px;
        padding-bottom: 16px;
        flex-grow: 1;
        align-items: flex-start;
    }

    .mobile-snap-container::-webkit-scrollbar {
        display: none;
    }

    .mobile-snap-item {
        flex: 0 0 100%;
        min-width: 100%;
        scroll-snap-align: start;
        scroll-snap-stop: always;
    }

    .app-title {
        color: var(--mud-palette-primary);
        font-size: 66px;
        letter-spacing: 2px;
        line-height: 1;
    }
</style>

<div class="d-flex flex-column gap-2 flex-grow-1" style="position: relative; height: 100%;">

    <MudOverlay Visible="LocalStorageLoading" DarkBackground="true" Absolute="true" ZIndex="9999">
        <MudStack AlignItems="AlignItems.Center">
            <MudText Class="app-title">RISØS</MudText>
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large"/>
        </MudStack>
    </MudOverlay>

    <MudPaper Elevation="0" Class="pa-2 border-2 mud-border-lines-default rounded-lg hide-in-export">
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Spacing="0">
                <MudText Typo="Typo.subtitle1" Color="Color.Primary" Class="font-weight-bold" Style="line-height: 1.1">
                    @StudyContext.FacultyAbbreviation
                </MudText>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary font-weight-bold">
                        @StudyContext.ProgramAbbreviation
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(StudyContext.ProgramSpecialization))
                    {
                        <MudDivider Vertical="true" FlexItem="true" Style="height: 10px; margin: auto 0; border-width: 1px;"/>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            @StudyContext.ProgramSpecialization
                        </MudText>
                    }
                </MudStack>
            </MudStack>
            <SubjectTypeLegend Spacing="2"/>
        </MudStack>
    </MudPaper>

    <div id="export-zone" class="d-flex flex-column gap-2">
        <div class="show-only-in-export px-1">
            <MudStack Spacing="0">
                <MudText Typo="Typo.h5" Color="Color.Primary" Class="font-weight-bold" Style="line-height: 1.1">
                    @StudyContext.FacultyAbbreviation
                </MudText>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.subtitle1" Class="mud-text-secondary font-weight-bold">
                        @StudyContext.ProgramAbbreviation
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(StudyContext.ProgramSpecialization))
                    {
                        <MudDivider Vertical="true" FlexItem="true" Style="height: 16px; margin: auto 0; border-width: 2px;"/>
                        <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">
                            @StudyContext.ProgramSpecialization
                        </MudText>
                    }
                </MudStack>
            </MudStack>
        </div>

        <ControlCenter RecognizedYear="@RecognizedYear" TotalCredits="@TotalCredits"/>

        <div class="mobile-snap-container pt-2">
            @foreach (var year in Enumerable.Range(RecognizedYear ? 0 : 1, StudyContext.Years + (RecognizedYear ? 1 : 0)))
            {
                var winterSemNumber = year * 2 - 1;
                var summerSemNumber = year * 2;
                var winterSemCode = winterSemNumber.ToString();
                var summerSemCode = summerSemNumber.ToString();

                var yearSubjects = Subjects.Where(s => s.Semester == winterSemCode || s.Semester == summerSemCode).ToList();
                var currentYear = DateTime.Now.Year;
                var yearDisplay = $"{currentYear + year - 1}/{currentYear + year}";

                var yearCredits = CreditCalculator.CalculateSemesterCredits(Subjects, winterSemNumber) + 
                                  CreditCalculator.CalculateSemesterCredits(Subjects, summerSemNumber);

                <div class="mobile-snap-item">
                    <div class="rounded-lg px-4 pb-2 d-flex flex-column mt-4 mb-2"
                         style="position: relative; border: 2px dotted var(--mud-palette-lines-default);">

                        <div style="position: absolute; top: -16px; left: 16px; background-color: var(--mud-palette-background); padding: 0 8px; white-space: nowrap; z-index: 10;">
                            <MudText Typo="Typo.h6" Color="Color.Primary" Class="font-weight-bold">@(year == 0 ? LanguageHelper.RecognizedYearTitle : $"{year}. {LanguageHelper.Years_One}")</MudText>
                        </div>

                        <MudStack Class="flex-grow-1 mt-4" Spacing="4">
                            <MobileSemesterBlock SemesterNumber="@winterSemNumber"
                                                 Season="SemesterSeason.Winter"
                                                 Subjects="@GetSubjectsForSemester(winterSemCode)"/>

                            <MobileSemesterBlock SemesterNumber="@summerSemNumber"
                                                 Season="SemesterSeason.Summer"
                                                 Subjects="@GetSubjectsForSemester(summerSemCode)"/>
                        </MudStack>

                        <MudStack AlignItems="AlignItems.Center" Row Justify="Justify.SpaceBetween" Spacing="1" Class="pt-2">
                            <div>
                                <GpaStatisticsMenu Subjects="@yearSubjects"
                                                   WeightedLabel="@string.Format(LanguageHelper.GpaYearlyWeighted, yearDisplay)"
                                                   CompulsoryLabel="@LanguageHelper.GpaYearlyCompulsory"
                                                   AnchorOrigin="Origin.TopLeft"
                                                   TransformOrigin="Origin.BottomLeft" />
                            </div>
                            <div class="d-flex align-center gap-1">
                                @if (yearCredits.Completed > 0)
                                {
                                    <MudText Typo="Typo.body1" Color="Color.Success" Class="font-weight-bold">@yearCredits.Completed</MudText>
                                    <MudText Typo="Typo.body1" Color="Color.Primary">/</MudText>
                                }
                                <MudText Typo="Typo.body1" Color="Color.Primary"><b>@yearCredits.Registered</b> @LanguageHelper.Credits</MudText>
                            </div>
                        </MudStack>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    public required StudyContext StudyContext { get; set; }

    [Parameter]
    [EditorRequired]
    public required IEnumerable<SubjectEntry> Subjects { get; set; }

    [Parameter]
    public bool RecognizedYear { get; set; }

    [Parameter]
    public bool LocalStorageLoading { get; set; }

    private Credits TotalCredits => CreditCalculator.CalculateTotalCredits(Subjects);

    private IEnumerable<SubjectEntry> GetSubjectsForSemester(string semesterCode) => Subjects.Where(s => s.Semester == semesterCode).OrderBy(s => s.Subject.Name);
}
