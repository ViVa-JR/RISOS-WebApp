@using RISOS.Enums
@using RISOS.Extensions
@using RISOS.Localization
@using RISOS.Models
@using RISOS.Pages.Home.Models

<MudStack Spacing="0" Class="flex-grow-1">
    <MudDropZone T="SubjectEntry" Identifier="@Semester.ToString()"
                 Class="pa-2 flex-grow-1 d-flex flex-column gap-2 border-2 border-b-0 border-dashed mud-border-lines-default rounded-t-lg"
                 Style="min-height: 250px"
                 CanDrop="CanDrop">
        <ChildContent>
            <MudStack Row Spacing="1" AlignItems="AlignItems.Center" Class="pa-2 border-b mud-border-lines-default mud-background-gray rounded-t-lg">
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">@Semester. @LanguageHelper.Semester •</MudText>
                <MudChip T="SemesterSeason" Value="@SemesterSeason" Text="@SemesterSeason.ToLabel()" Size="Size.Small" Variant="Variant.Text"
                         Color="@SemesterSeason.ToColor()"/>
            </MudStack>
        </ChildContent>
    </MudDropZone>

    <MudStack AlignItems="AlignItems.Center" Row Justify="Justify.FlexEnd" Spacing="1" Class="border-2 border-t-0 border-dashed mud-border-lines-default rounded-b-lg pa-2">
        @if (Credits.Completed > 0)
        {
            <MudText Typo="Typo.body1" Color="Color.Success">@Credits.Completed</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">/</MudText>
        }
        <MudText Typo="Typo.body1" Color="Color.Secondary">
            @Credits.Registered @LanguageHelper.Credits
        </MudText>
    </MudStack>

</MudStack>

@code {
    [Parameter, EditorRequired]
    public required int Semester { get; set; }

    [Parameter]
    public SemesterSeason SemesterSeason { get; set; }

    [Parameter]
    public Credits Credits { get; set; } = new();

    public bool CanDrop(SubjectEntry entry)
        => Semester < 1 || ((entry.Subject.SemesterSeason == SemesterSeason || entry.Subject.SemesterSeason == SemesterSeason.Any)
           && entry.Subject.MinSemester <= Semester);

}