@using FastCloner
@using RISOS.Enums
@using RISOS.Extensions
@using RISOS.Localization
@using RISOS.Pages.Home.Dialogs.AddCustomSubjectDialog
@using RISOS.Pages.Home.Dialogs.GradeSelectionDialog
@using RISOS.Pages.Home.Models
@using RISOS.Services
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LocalStorageService LocalStorageService

<style>
    .subject-link {
        text-decoration: none;
        color: var(--mud-palette-text-primary) !important;
        font-weight: bold;
    }

    .subject-link:hover {
        text-decoration: underline;
    }
</style>

<MudPaper Elevation="2" Style="cursor: grab; min-width: 280px; transform: translate3d(0,0,0); -webkit-user-select: none; user-select: none;">
    <MudMenu ActivationEvent="MouseEvent.RightClick" Dense Class="pa-2 d-flex align-center" Style="width: 100%">
        <ActivatorContent>
            <div @oncontextmenu="@context.ToggleAsync" @oncontextmenu:preventDefault style="width: 100%">
                <MudStack Row AlignItems="AlignItems.Center" Style="width: 100%">
                    <MudAvatar Variant="Variant.Filled" Color="@Entry.Subject.Type.ToColor()" Class="rounded"
                               Style="min-width: 48px; width: auto; padding: 0 8px; height: 48px; flex-shrink: 0;">
                        <MudText Typo="Typo.button" Style="font-size: 0.85rem; font-weight: bold; white-space: nowrap;">
                            @Entry.Subject.ShortName
                        </MudText>
                    </MudAvatar>

                    <div class="d-flex flex-column flex-grow-1 overflow-hidden">

                        <MudTooltip RootClass="d-flex" Text="@Entry.Subject.Name">
                            @if (string.IsNullOrWhiteSpace(Entry.Subject.Url))
                            {
                                <MudText Typo="Typo.subtitle2" Class="card-text">
                                    @Entry.Subject.Name
                                </MudText>
                            }
                            else
                            {
                                <MudLink Href="@Entry.Subject.Url" Target="_blank" Class="subject-link">
                                    <MudText Typo="Typo.subtitle2" Class="card-text">
                                        @Entry.Subject.Name
                                    </MudText>
                                </MudLink>
                            }
                        </MudTooltip>

                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                            @if (!Entry.IsAssigned)
                            {
                                <MudChip T="SemesterSeason" Value="@Entry.Subject.SemesterSeason"
                                         Text="@Entry.Subject.SemesterSeason.ToLabel()" Size="Size.Small"
                                         Variant="Variant.Text"
                                         Color="@Entry.Subject.SemesterSeason.ToColor()" Style="font-size: 0.7rem;"/>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">•</MudText>
                            }
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @Entry.Subject.Credits @LanguageHelper.Cr •
                            </MudText>
                            <MudTooltip Text="@Entry.Subject.CompletionType.GetDescription()">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @Entry.Subject.CompletionType.ToLabel().ToUpper()
                                </MudText>
                            </MudTooltip>
                        </MudStack>
                    </div>
                    @if (Entry.IsAssigned)
                    {
                        <SubjectStatusIndicator Entry="@Entry" OnClick="@ToggleGrade" />
                    }
                </MudStack>
            </div>
        </ActivatorContent>
        <ChildContent>
            <MudMenu StartIcon="@Icons.Material.Filled.Subject" IconColor="Color.Primary" Label="@LanguageHelper.MoveTo"
                     Dense>
                @if (Entry.Semester != SubjectEntry.Unassigned)
                {
                    <MudMenuItem Label="@LanguageHelper.Unassigned" OnClick="@(() => MoveEntry(SubjectEntry.Unassigned))"/>
                }

                @if (RecognizedYear && Entry.Semester != "-1" && Entry.Semester != "0")
                {
                    var preferredRecognized = Entry.Subject.SemesterSeason == SemesterSeason.Summer ? 0 : -1;
                    <MudMenuItem Label="@LanguageHelperExtensions.Semester(preferredRecognized)" OnClick="@(() => MoveEntry(preferredRecognized.ToString()))"/>
                }

                @foreach (var semester in Enumerable.Range(1, SemesterCount))
                {
                    if (CanMove(semester))
                    {
                        <MudMenuItem Label="@LanguageHelperExtensions.Semester(semester)" OnClick="@(() => MoveEntry(semester.ToString()))"/>
                    }
                }
            </MudMenu>
            @if (StudyContext.GpaPredictor && Entry.Completed == true && Entry.Subject.CompletionType.IsGraded())
            {
                <MudMenuItem Icon="@Icons.Material.Filled.Grade" Label="@LanguageHelper.GradeSelection_Title" OnClick="@(() => CompletedChanged(true))"/>
            }
            @if (Entry.IsSport || Entry is { LatestAttempt: true, Completed: false })
            {
                <MudMenuItem Icon="@(Entry.IsSport ? Icons.Material.Filled.ContentCopy : Icons.Material.Filled.RestartAlt)" Label="@(Entry.IsSport ? LanguageHelper.Repeat : LanguageHelper.Retake)"
                             OnClick="@(() => RetakeEntry.InvokeAsync(Entry))"/>
            }
            @if (Entry.IsCustomSubject)
            {
                <MudMenuItem Icon="@Icons.Material.Filled.ContentCopy" Label="@LanguageHelper.Repeat" OnClick="@OnCloneClick"/>
                <MudMenuItem Icon="@Icons.Material.Filled.Edit" Label="@LanguageHelper.Edit" OnClick="@OnEditClick"/>
            }
            @if (Entry.Subject.Type != SubjectType.Compulsory || Entry.IsCustomSubject || Entry.Attempt > 1)
            {
                <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" Label="@LanguageHelper.Delete" OnClick="@(() => RemoveEntry.InvokeAsync(Entry))"/>
            }
        </ChildContent>
    </MudMenu>
</MudPaper>

@code {
    [CascadingParameter]
    public StudyContext StudyContext { get; set; } = null!;

    [Parameter]
    [EditorRequired]
    public required SubjectEntry Entry { get; set; }

    [Parameter]
    public EventCallback<SubjectEntry> EntryChanged { get; set; }

    [Parameter]
    public int SemesterCount { get; set; }

    [Parameter]
    public bool RecognizedYear { get; set; }

    [Parameter]
    public EventCallback<SubjectEntry> RemoveEntry { get; set; }

    [Parameter]
    public EventCallback<SubjectEntry> AddEntry { get; set; }

    [Parameter]
    public EventCallback<SubjectEntry> RetakeEntry { get; set; }

    private bool CanMove(int semester)
    {
        if (semester <= 0)
        {
            return Entry.Semester != semester.ToString() &&
                   Entry.Subject.SemesterSeason.IsValidForSemester(semester);
        }

        return Entry.Semester != semester.ToString() &&
               Entry.Subject.MinSemester <= semester &&
               Entry.Subject.SemesterSeason.IsValidForSemester(semester);
    }

    private async Task MoveEntry(string zone)
    {
        Entry.Semester = zone;
        await EntryChanged.InvokeAsync(Entry);
    }

    private async Task ToggleGrade()
    {
        if (StudyContext.GpaPredictor && Entry.Subject.CompletionType.IsGraded())
        {
            await OpenGradeDialog();
            return;
        }

        if (Entry.Completed == null)
        {
            await CompletedChanged(true);
        }
        else if (Entry.Completed == true)
        {
            await CompletedChanged(false);
        }
        else
        {
            await CompletedChanged(null);
        }
    }

    private async Task OpenGradeDialog()
    {
        var result = await GradeSelectionDialog.ShowAsync(DialogService, Entry.Grade);
        if (result.IsSuccess)
        {
            Entry.Grade = result.Value;
            if (Entry.Grade == null)
            {
                Entry.Completed = null;
            }
            else
            {
                Entry.Completed = Entry.Grade != Grade.F;
            }
            await EntryChanged.InvokeAsync(Entry);
        }
    }

    private async Task CompletedChanged(bool? arg)
    {
        if (StudyContext.GpaPredictor && Entry.Subject.CompletionType.IsGraded() && (arg == true || (arg == null && Entry.Grade != null)))
        {
            await OpenGradeDialog();
            return;
        }

        Entry.Completed = arg;

        if (Entry.Subject.CompletionType.IsGraded())
        {
            if (arg == true)
            {
                // If it's now success, ensure it has a grade. 
                // Default to A if it was null or F, so data matches the visual default.
                if (Entry.Grade == null || Entry.Grade == Grade.F)
                {
                    Entry.Grade = Grade.A;
                }
            }
            else if (arg == false)
            {
                Entry.Grade = Grade.F;
            }
            else
            {
                Entry.Grade = null;
            }
        }

        await EntryChanged.InvokeAsync(Entry);
    }

    private async Task OnEditClick()
    {
        var result = await CreateEditCustomSubjectDialog.ShowAsync(DialogService, Entry);
        if (result.IsSuccess)
        {
            FastCloner.DeepCloneTo(result.Value, Entry);
            await LocalStorageService.UpdateSubjectAsync(Entry);
            await EntryChanged.InvokeAsync(Entry);
            Snackbar.Add(LanguageHelper.SubjectUpdated, Severity.Success);
        }
    }

    private async Task OnCloneClick()
    {
        var clone = FastCloner.DeepClone(Entry);
        if (clone is null)
        {
            return;
        }

        clone.Subject.Id = CustomSubjectModel.GenerateNewId();
        clone.Semester = SubjectEntry.Unassigned;
        await AddEntry.InvokeAsync(clone);
    }
}
