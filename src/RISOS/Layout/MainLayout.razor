@using RISOS.Services

@inherits LayoutComponentBase
@implements IDisposable

@inject ThemeStateService ThemeStateService
@inject IJSRuntime Js

<MudThemeProvider
    @ref="_mudThemeProvider"
    IsDarkMode="@ThemeStateService.IsDarkMode"
    Theme="@ThemeStateService.Theme"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>
<MudBreakpointProvider OnBreakpointChanged="OnBreakpointChanged"/>

<MudLayout>
    <MudMainContent class="pt-5 px-5" Style="height: 100vh">
        <CascadingValue Value="@_isReadOnly">
            @Body
        </CascadingValue>
    </MudMainContent>
</MudLayout>

@code {
    private MudThemeProvider _mudThemeProvider = null!;

    private bool _isReadOnly;

    protected override async Task OnInitializedAsync()
    {
        ThemeStateService.OnChange += StateHasChanged;
        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _mudThemeProvider.WatchSystemDarkModeAsync(ThemeStateService.SetDarkMode);
            await Js.InvokeVoidAsync("initDragScroll");
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    public void Dispose()
    {
        ThemeStateService.OnChange -= StateHasChanged;
    }

    private void OnBreakpointChanged(Breakpoint breakpoint)
    {
        var readOnly = breakpoint is Breakpoint.Sm or Breakpoint.Xs;
        if (_isReadOnly == readOnly)
        {
            return;
        }

        _isReadOnly = readOnly;
        StateHasChanged();
    }
}
