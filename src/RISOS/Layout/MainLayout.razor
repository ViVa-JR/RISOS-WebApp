@using RISOS.Services

@inherits LayoutComponentBase
@implements IDisposable

@inject ThemeStateService ThemeStateService

<MudThemeProvider @ref="_mudThemeProvider" IsDarkMode="@ThemeStateService.IsDarkMode" IsDarkModeChanged="@ThemeStateService.SetDarkMode" Theme="@ThemeStateService.Theme"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <CascadingValue TValue="MudThemeProvider" Value="@_mudThemeProvider">
        <MudMainContent class="pt-5 px-5" Style="height: 100vh">
            @Body
        </MudMainContent>
    </CascadingValue>
</MudLayout>

@code {
    private MudThemeProvider _mudThemeProvider = null!;

    protected override async Task OnInitializedAsync()
    {
        ThemeStateService.OnChange += StateHasChanged;
        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _mudThemeProvider.WatchSystemDarkModeAsync(ThemeStateService.SetDarkMode);
        }
        
        await base.OnAfterRenderAsync(firstRender);
    }
    
    public void Dispose()
    {
        ThemeStateService.OnChange -= StateHasChanged;
    }

}
