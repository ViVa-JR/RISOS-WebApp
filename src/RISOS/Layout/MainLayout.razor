@inherits LayoutComponentBase
@using RISOS.Services
@implements IDisposable

@inject ThemeStateService ThemeStateService
@inject IJSRuntime Js

<MudThemeProvider
    @ref="_mudThemeProvider"
    IsDarkMode="@ThemeStateService.IsDarkMode"
    Theme="@ThemeStateService.Theme"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    <MudMainContent class="pt-5 px-5" Style="height: 100vh">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private MudThemeProvider _mudThemeProvider = null!;

    protected override async Task OnInitializedAsync()
    {
        ThemeStateService.OnChange += StateHasChanged;
        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _mudThemeProvider.WatchSystemDarkModeAsync(ThemeStateService.SetDarkMode);
            await Js.InvokeVoidAsync("initDragScroll");
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    public void Dispose() => ThemeStateService.OnChange -= StateHasChanged;
}
