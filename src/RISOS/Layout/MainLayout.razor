@using RISOS.Services

@inherits LayoutComponentBase
@implements IDisposable

@inject ThemeStateService ThemeStateService

<MudThemeProvider 
    @ref="_mudThemeProvider" 
    IsDarkMode="@ThemeStateService.IsDarkMode" 
    Theme="@ThemeStateService.Theme"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<MudLayout>
    @if (ThemeStateService.IsInitialized)
    {
        <MudMainContent class="pt-5 px-5" Style="height: 100vh">
            @Body
        </MudMainContent>
    }
    else
    {
        <div style="background-color: #f8fafc; height: 100vh;"></div>
    }
</MudLayout>

@code {
    private MudThemeProvider _mudThemeProvider = null!;

    protected override async Task OnInitializedAsync()
    {
        ThemeStateService.OnChange += StateHasChanged;
        
        try 
        {
            await ThemeStateService.InitializeAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Chyba při načítání témat: {ex.Message}");
        }
        
        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _mudThemeProvider.WatchSystemDarkModeAsync(ThemeStateService.SetDarkMode);
        }
        
        await base.OnAfterRenderAsync(firstRender);
    }
    
    public void Dispose()
    {
        ThemeStateService.OnChange -= StateHasChanged;
    }

}
